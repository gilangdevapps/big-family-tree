---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Build and explore your family tree with Big Family Tree.">
  <header class="site-nav">
    <div class="container nav-inner">
      <a href="/" class="wordmark">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
          <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
          <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
          <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
          <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
          <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
          <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
        </svg>
        <span>Big Family Tree</span>
      </a>
      <nav class="nav-links">
        <a href="/auth/magic-link" class="btn btn-ghost">Sign in</a>
        <a href="/auth/magic-link" class="btn btn-primary">Get started</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="hero-eyebrow">Your family's story, preserved</p>
          <h1 class="hero-headline">
            Trace your roots.<br />
            Connect your people.
          </h1>
          <p class="hero-body">
            Big Family Tree is a private, collaborative space to build and explore your family history — together. Start with what you know, grow it over time, and keep your heritage alive for future generations.
          </p>
          <div class="hero-actions">
            <a href="/auth/magic-link" class="btn btn-primary btn-lg">
              Start your tree — it's free
            </a>
            <a href="#features" class="btn btn-ghost btn-lg">Learn more</a>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="tree-illustration">
            <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Root node -->
              <circle cx="150" cy="150" r="24" fill="var(--color-surface-container-high)"/>
              <circle cx="150" cy="150" r="20" fill="var(--color-surface-container-highest)"/>
              <text x="150" y="155" text-anchor="middle" font-family="Newsreader, serif" font-size="10" fill="var(--color-on-surface)">You</text>
              <!-- Branch lines radiating out -->
              <g stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round">
                <line x1="150" y1="126" x2="80" y2="60"/>
                <line x1="150" y1="126" x2="220" y2="60"/>
                <line x1="150" y1="174" x2="80" y2="240"/>
                <line x1="150" y1="174" x2="220" y2="240"/>
                <line x1="174" y1="150" x2="250" y2="150"/>
                <line x1="126" y1="150" x2="50" y2="150"/>
              </g>
              <!-- Generation 1 nodes -->
              <circle cx="80" cy="60" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="80" cy="60" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="80" y="65" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Father</text>
              <circle cx="220" cy="60" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="220" cy="60" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="220" y="65" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Mother</text>
              <circle cx="80" cy="240" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="80" cy="240" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="80" y="245" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Sibling</text>
              <circle cx="220" cy="240" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="220" cy="240" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="220" y="245" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Spouse</text>
              <circle cx="250" cy="150" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="250" cy="150" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="250" y="155" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Child</text>
              <circle cx="50" cy="150" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="50" cy="150" r="14" fill="var(--color-surface-container-highest)"/>
              <text x="50" y="155" text-anchor="middle" font-family="Newsreader, serif" font-size="9" fill="var(--color-on-surface)">Aunt</text>
              <!-- Generation 2 nodes (smaller) -->
              <circle cx="45" cy="35" r="10" fill="var(--color-primary-fixed)"/>
              <circle cx="115" cy="35" r="10" fill="var(--color-primary-fixed)"/>
              <circle cx="45" cy="265" r="10" fill="var(--color-primary-fixed)"/>
              <circle cx="115" cy="265" r="10" fill="var(--color-primary-fixed)"/>
              <line x1="80" y1="46" x2="45" y2="35" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2"/>
              <line x1="80" y1="46" x2="115" y2="35" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2"/>
              <line x1="80" y1="254" x2="45" y2="265" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2"/>
              <line x1="80" y1="254" x2="115" y2="265" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3 2"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features">
      <div class="container">
        <div class="features-header">
          <h2 class="features-headline">Built for how families actually work</h2>
          <p class="features-subtext">Big Family Tree adapts to your family's complexity — simple enough for a beginner, powerful enough for generations of research.</p>
        </div>
        <ul class="features-grid">
          <li class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round">
                <circle cx="12" cy="8" r="4"/>
                <circle cx="6" cy="20" r="3"/>
                <circle cx="18" cy="20" r="3"/>
                <line x1="12" y1="12" x2="6" y2="17"/>
                <line x1="12" y1="12" x2="18" y2="17"/>
              </svg>
            </div>
            <h3>Visual family tree</h3>
            <p>An interactive radial diagram that grows with your tree. Click any name to explore that person's full profile and connections.</p>
          </li>
          <li class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3>Invite family members</h3>
            <p>Share access with close family so everyone can add what they know. Admins control who can view and edit.</p>
          </li>
          <li class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M9 21V9"/>
              </svg>
            </div>
            <h3>Rich profiles</h3>
            <p>Birth dates and places, occupations, stories, photos, and more — every person in your tree gets a full profile.</p>
          </li>
          <li class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>Private by default</h3>
            <p>Your family tree is visible only to people you invite. Your data stays yours — no public profiles, no social sharing.</p>
          </li>
        </ul>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container cta-inner">
        <h2 class="cta-headline">Ready to start your family's story?</h2>
        <p class="cta-body">Create your free account in seconds. No credit card, no commitment — just your family's history, waiting to be discovered.</p>
        <a href="/auth/magic-link" class="btn btn-primary btn-lg">Create your family tree</a>
        <p class="cta-note">Already have an account? <a href="/auth/magic-link">Sign in</a></p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="footer-text">
        <span class="text-display">Big Family Tree</span> — preserve your heritage, connect your people.
      </p>
      <nav class="footer-nav" aria-label="Footer">
        <a href="/auth/magic-link">Sign in</a>
        <a href="#features">Features</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  /* --- Navigation --- */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .wordmark span {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-on-surface);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* --- Hero --- */
  .hero {
    padding-block: var(--space-24) var(--space-20);
    background: radial-gradient(ellipse at 70% 50%, var(--color-surface-container) 0%, transparent 70%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .hero-eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: var(--space-4);
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
    color: var(--color-on-surface);
  }

  .hero-body {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-8);
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .tree-illustration {
    width: 100%;
    max-width: 340px;
    opacity: 0.9;
  }

  .tree-illustration svg {
    width: 100%;
    height: auto;
  }

  /* --- Features --- */
  .features {
    padding-block: var(--space-20) var(--space-24);
  }

  .features-header {
    text-align: center;
    max-width: 52ch;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .features-headline {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: var(--space-4);
  }

  .features-subtext {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
  }

  .features-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-8);
  }

  .feature-item {
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background-color: var(--color-surface-container-low);
    border: 1px solid var(--color-outline-variant);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-fixed);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
  }

  .feature-item h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .feature-item p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  /* --- CTA Section --- */
  .cta-section {
    padding-block: var(--space-20);
    background-color: var(--color-surface-container);
    text-align: center;
  }

  .cta-inner {
    max-width: 52ch;
    margin-inline: auto;
  }

  .cta-headline {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: var(--space-4);
  }

  .cta-body {
    font-size: var(--text-lg);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-8);
  }

  .cta-note {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  /* --- Footer --- */
  .site-footer {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-outline-variant);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-text {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-6);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-visual {
      order: -1;
    }

    .tree-illustration {
      max-width: 240px;
    }

    .hero-body {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Verifying…">
  <div class="verify-shell">
    <div class="verify-card">
      <div class="verify-icon" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="22" stroke="var(--color-primary)" stroke-width="2" stroke-dasharray="6 4" class="spinner-ring"/>
          <path d="M24 14v10l6 6" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1 class="verify-title">Verifying your link…</h1>
      <p class="verify-body">Just a moment while we confirm your identity.</p>
    </div>
  </div>
</Layout>

<script>
  // With localStorage auth, instantly redirect based on session
  const user = localStorage.getItem('bft_current_user');
  if (user) {
    window.location.href = '/dashboard';
  } else {
    window.location.href = '/auth/magic-link';
  }
</script>

<style>
  .verify-shell {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .verify-card {
    text-align: center;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .verify-title {
    font-size: var(--text-2xl);
  }

  .verify-body {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .spinner-ring {
    animation: spin 1s linear infinite;
    transform-origin: center;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

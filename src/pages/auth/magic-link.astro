---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sign in">
  <div class="auth-shell">
    <div class="auth-card">
      <header class="auth-header">
        <a href="/" class="wordmark">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </header>

      <div class="auth-body">
        <div id="form-state">
          <h1 class="auth-title">Sign in to Big Family Tree</h1>
          <p class="auth-subtext">Enter your email and we'll send you a link to sign in instantly.</p>

          <form id="magic-link-form" class="auth-form">
            <div class="form-group">
              <label for="email" class="form-label">Email address</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="you@example.com"
                autocomplete="email"
                required
              />
              <p id="email-error" class="form-error" aria-live="polite" hidden></p>
            </div>

            <div id="server-error" class="auth-server-error" hidden></div>

            <button type="submit" class="btn btn-primary btn-lg auth-submit" id="submit-btn">
              <span id="btn-label">Send magic link</span>
              <span id="btn-spinner" class="spinner" hidden></span>
            </button>
          </form>
        </div>

        <div id="success-state" class="auth-success" hidden>
          <div class="success-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="23" stroke="var(--color-primary)" stroke-width="2"/>
              <path d="M14 24l7 7 13-13" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="success-title">Check your inbox</h2>
          <p class="success-body" id="success-email">
            We sent a sign-in link to <strong id="sent-email"></strong>.
            It expires in 24 hours.
          </p>
          <button type="button" class="btn btn-ghost" id="resend-btn">
            Didn't get it? Send again
          </button>
          <p class="success-home-link">
            <a href="/">&larr; Back to home</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('magic-link-form') as HTMLFormElement;
  const formState = document.getElementById('form-state')!;
  const successState = document.getElementById('success-state')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label')!;
  const btnSpinner = document.getElementById('btn-spinner')!;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const emailError = document.getElementById('email-error')!;
  const serverError = document.getElementById('server-error')!;
  const sentEmail = document.getElementById('sent-email')!;
  const resendBtn = document.getElementById('resend-btn')!;

  // Handle URL params for error state
  const params = new URLSearchParams(window.location.search);
  const errorMsg = params.get('error');
  if (errorMsg) {
    showServerError(decodeURIComponent(errorMsg));
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    setLoading(true);

    const email = emailInput.value.trim();

    try {
      const res = await fetch('/api/auth/magic-link', {
        method: 'POST',
        body: new URLSearchParams({ email }),
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      });

      const data = await res.json();

      if (!res.ok) {
        if (res.status === 400 && data.error.includes('email')) {
          showEmailError(data.error);
        } else {
          showServerError(data.error || 'Something went wrong. Please try again.');
        }
        setLoading(false);
        return;
      }

      // Show success state
      sentEmail.textContent = email;
      formState.hidden = true;
      successState.hidden = false;
    } catch {
      showServerError('Network error. Please check your connection and try again.');
      setLoading(false);
    }
  });

  resendBtn.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    setLoading(true);
    successState.hidden = true;
    formState.hidden = false;

    try {
      const res = await fetch('/api/auth/magic-link', {
        method: 'POST',
        body: new URLSearchParams({ email }),
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      });
      const data = await res.json();
      if (!res.ok) {
        showServerError(data.error || 'Failed to resend. Please try again.');
        setLoading(false);
        return;
      }
      sentEmail.textContent = email;
      formState.hidden = true;
      successState.hidden = false;
    } catch {
      showServerError('Network error. Please try again.');
      formState.hidden = false;
      successState.hidden = true;
      setLoading(false);
    }
  });

  function setLoading(on: boolean) {
    submitBtn.disabled = on;
    emailInput.disabled = on;
    btnLabel.hidden = on;
    btnSpinner.hidden = !on;
  }

  function showEmailError(msg: string) {
    emailInput.classList.add('error');
    emailError.textContent = msg;
    emailError.hidden = false;
  }

  function showServerError(msg: string) {
    serverError.textContent = msg;
    serverError.hidden = false;
  }

  function clearErrors() {
    emailInput.classList.remove('error');
    emailError.hidden = true;
    serverError.hidden = true;
  }
</script>

<style>
  .auth-shell {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: radial-gradient(ellipse at 50% 30%, var(--color-surface-container) 0%, transparent 60%);
  }

  .auth-card {
    width: 100%;
    max-width: 440px;
    background-color: var(--color-surface-container-lowest);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-outline-variant);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }

  .auth-header {
    padding: var(--space-6);
    border-bottom: 1px solid var(--color-outline-variant);
    background-color: var(--color-surface-container-low);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .wordmark span {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .auth-body {
    padding: var(--space-8);
  }

  .auth-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .auth-subtext {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-6);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .auth-submit {
    width: 100%;
    justify-content: center;
  }

  .auth-server-error {
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
  }

  /* Success state */
  .auth-success {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .success-icon {
    margin-bottom: var(--space-2);
  }

  .success-title {
    font-size: var(--text-2xl);
  }

  .success-body {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .success-home-link {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }
</style>

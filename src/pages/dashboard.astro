---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
  <div class="dashboard-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href="/" class="wordmark">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
        <div class="nav-right">
          <div class="search-wrap" id="search-wrap">
            <div class="search-input-wrap">
              <svg class="search-icon" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                <circle cx="9" cy="9" r="6"/>
                <path d="M13 13l4 4"/>
              </svg>
              <input
                type="search"
                id="global-search"
                class="search-input"
                placeholder="Search members…"
                autocomplete="off"
                aria-label="Search family members"
                aria-expanded="false"
                aria-autocomplete="list"
                aria-controls="search-results"
              />
              <kbd class="search-kbd" aria-hidden="true">/</kbd>
            </div>
            <div id="search-results" class="search-results" role="listbox" aria-label="Search results" hidden></div>
          </div>
          <span class="user-email" id="user-email-display"></span>
          <form method="POST" action="/auth/sign-out" style="display:contents">
            <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
          </form>
        </div>
      </div>
    </header>

    <main class="dashboard-main container">
      <div class="page-header">
        <h1 class="page-title">Your family trees</h1>
        <a href="/tree/new" class="btn btn-primary" id="new-tree-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="8" y1="2" x2="8" y2="14"/>
            <line x1="2" y1="8" x2="14" y2="8"/>
          </svg>
          New tree
        </a>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state">
        <div class="empty-visual" aria-hidden="true">
          <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
            <circle cx="60" cy="60" r="55" fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1"/>
            <!-- Simplified tree icon -->
            <circle cx="60" cy="50" r="14" fill="var(--color-primary-fixed)"/>
            <circle cx="38" cy="78" r="10" fill="var(--color-secondary-fixed)"/>
            <circle cx="82" cy="78" r="10" fill="var(--color-secondary-fixed)"/>
            <line x1="60" y1="64" x2="38" y2="68" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round"/>
            <line x1="60" y1="64" x2="82" y2="68" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round"/>
            <line x1="38" y1="78" x2="82" y2="78" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round"/>
            <!-- Plus icon -->
            <circle cx="60" cy="50" r="14" fill="none" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="60" y1="43" x2="60" y2="57" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/>
            <line x1="53" y1="50" x2="67" y2="50" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h2 class="empty-title">Your family story starts here</h2>
        <p class="empty-body">
          Create your first tree and invite family members to collaborate. Start with yourself, or begin with someone you know well.
        </p>
        <a href="/tree/new" class="btn btn-primary btn-lg">
          Create your first tree
        </a>
      </div>

      <!-- Tree Grid (populated state — shown via JS when trees exist) -->
      <div id="tree-grid" class="tree-grid" hidden>
        <!-- Trees rendered here by JS -->
      </div>
    </main>
  </div>
</Layout>

<script>
  import { seedDemoData, getCurrentUser } from '../../lib/store';

  // Seed demo data so the user immediately sees a tree
  seedDemoData();

  // Auth check
  const user = getCurrentUser();
  if (!user) {
    window.location.href = '/auth/magic-link';
  }

  // Populate user email in nav
  const emailDisplay = document.getElementById('user-email-display');
  if (emailDisplay && user) emailDisplay.textContent = user.email;

  // Load trees for the current user
  async function loadTrees() {
    const emptyState = document.getElementById('empty-state')!;
    const treeGrid = document.getElementById('tree-grid')!;

    try {
      const res = await fetch('/api/trees');
      if (!res.ok) throw new Error();

      const trees = await res.json();
      if (!trees || trees.length === 0) return;

      emptyState.hidden = true;
      treeGrid.hidden = false;

      trees.forEach((tree: any) => {
        const card = document.createElement('a');
        card.href = `/tree/${tree.id}`;
        card.className = 'tree-card';
        card.innerHTML = `
          <div class="tree-card-body">
            <h3 class="tree-card-name">${escapeHtml(tree.name)}</h3>
            <p class="tree-card-meta">
              ${tree.member_count ?? 0} member${tree.member_count !== 1 ? 's' : ''}
              ${tree.updated_at ? ` · last edited ${formatDate(tree.updated_at)}` : ''}
            </p>
          </div>
          <span class="tree-card-open">
            Open
            <span aria-hidden="true"> &rarr;</span>
          </span>
        `;
        treeGrid.appendChild(card);
      });
    } catch {
      // Keep showing empty state on error
    }
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  loadTrees();

  // --- Global Search ---
  const searchInput = document.getElementById('global-search') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;
  const searchWrap = document.getElementById('search-wrap') as HTMLDivElement;
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;
  let activeIndex = -1;
  let currentResults: any[] = [];

  function showResults() {
    searchResults.hidden = false;
    searchInput.setAttribute('aria-expanded', 'true');
    // Add overlay
    const overlay = document.createElement('div');
    overlay.className = 'search-overlay';
    overlay.id = 'search-overlay';
    overlay.setAttribute('aria-hidden', 'true');
    overlay.addEventListener('click', hideResults);
    document.body.appendChild(overlay);
  }

  function hideResults() {
    searchResults.hidden = true;
    searchInput.setAttribute('aria-expanded', 'false');
    activeIndex = -1;
    const overlay = document.getElementById('search-overlay');
    overlay?.remove();
  }

  function renderResults(results: any[], query: string) {
    activeIndex = -1;
    currentResults = results;

    if (results.length === 0) {
      searchResults.innerHTML = `
        <div class="search-empty">No members found for "${escapeHtml(query)}"</div>
      `;
      showResults();
      return;
    }

    searchResults.innerHTML = `
      <div class="search-results-header">${results.length} result${results.length !== 1 ? 's' : ''}</div>
      ${results.map((r, i) => `
        <a href="/tree/${r.tree_id}/person/${r.id}" class="search-result-item" role="option" data-index="${i}">
          <div class="search-result-avatar">
            ${r.profile_photo_url
              ? `<img src="${r.profile_photo_url}" alt="${r.first_name} ${r.last_name}'s photo" />`
              : `${r.first_name[0]}${r.last_name[0]}`
            }
          </div>
          <div class="search-result-info">
            <div class="search-result-name">${escapeHtml(r.first_name)} ${escapeHtml(r.last_name)}</div>
            <div class="search-result-tree">${escapeHtml(r.tree_name)}</div>
          </div>
          ${r.birth_date ? `<span class="search-result-dates">${new Date(r.birth_date).getFullYear()}</span>` : ''}
        </a>
      `).join('')}
    `;
    showResults();
  }

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.trim();

    if (searchTimeout) clearTimeout(searchTimeout);

    if (query.length < 2) {
      hideResults();
      return;
    }

    searchResults.innerHTML = `<div class="search-loading"><div class="spinner"></div> Searching…</div>`;
    showResults();

    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/search/members?q=${encodeURIComponent(query)}`, {
          credentials: 'include',
        });
        if (!res.ok) throw new Error();
        const data = await res.json();
        renderResults(data, query);
      } catch {
        searchResults.innerHTML = `<div class="search-empty">Search failed. Please try again.</div>`;
        showResults();
      }
    }, 300);
  });

  searchInput?.addEventListener('keydown', (e) => {
    const items = searchResults.querySelectorAll('.search-result-item');

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      updateActive(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, -1);
      updateActive(items);
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault();
      (items[activeIndex] as HTMLAnchorElement)?.click();
    } else if (e.key === 'Escape') {
      hideResults();
      searchInput.blur();
    }
  });

  function updateActive(items: NodeListOf<Element>) {
    items.forEach((item, i) => {
      item.classList.toggle('active', i === activeIndex);
    });
    if (activeIndex >= 0) {
      (items[activeIndex] as HTMLElement)?.scrollIntoView({ block: 'nearest' });
    }
  }

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!searchWrap?.contains(e.target as Node)) {
      hideResults();
    }
  });

  // Keyboard shortcut: / to focus search
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      searchInput?.focus();
    }
  });
</script>

<style>
  .dashboard-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* --- Top Nav --- */
  .top-nav {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-4);
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .wordmark span {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .user-email {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .btn-sm {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
  }

  /* --- Search --- */
  .search-wrap {
    position: relative;
  }

  .search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 10px;
    color: var(--color-on-surface-variant);
    pointer-events: none;
  }

  .search-input {
    width: 200px;
    padding: var(--space-2) var(--space-4);
    padding-left: 34px;
    padding-right: 32px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-on-surface);
    background-color: var(--color-surface-container-low);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint),
                width var(--duration-base) var(--ease-out-quint),
                background-color var(--duration-fast) var(--ease-out-quint);
  }

  .search-input::placeholder {
    color: var(--color-on-surface-variant);
    opacity: 0.7;
  }

  .search-input:focus {
    border-color: var(--color-primary);
    background-color: var(--color-surface-container-lowest);
    width: 280px;
  }

  .search-kbd {
    position: absolute;
    right: 10px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-on-surface-variant);
    background-color: var(--color-surface-container-high);
    border: 1px solid var(--color-outline-variant);
    border-radius: 3px;
    padding: 1px 5px;
    pointer-events: none;
    opacity: 0.8;
  }

  .search-input:focus ~ .search-kbd,
  .search-input:not(:placeholder-shown) ~ .search-kbd {
    display: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 340px;
    max-height: 420px;
    overflow-y: auto;
    background-color: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-2);
    z-index: 200;
  }

  .search-results-header {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .search-result-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: transparent;
    border: none;
    text-align: left;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quint);
    text-decoration: none;
    color: inherit;
  }

  .search-result-item:hover,
  .search-result-item:focus-visible {
    background-color: var(--color-surface-container-low);
    outline: none;
  }

  .search-result-item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }

  .search-result-avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-fixed-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-primary-fixed);
    flex-shrink: 0;
    overflow: hidden;
  }

  .search-result-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-result-info {
    flex: 1;
    min-width: 0;
  }

  .search-result-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-on-surface);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-tree {
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-dates {
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
    flex-shrink: 0;
  }

  .search-empty {
    padding: var(--space-8) var(--space-4);
    text-align: center;
    color: var(--color-on-surface-variant);
    font-size: var(--text-sm);
  }

  .search-loading {
    padding: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--color-on-surface-variant);
    font-size: var(--text-sm);
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 199;
  }

  @media (max-width: 640px) {
    .search-input { width: 140px; }
    .search-input:focus { width: 180px; }
    .search-results { right: -8px; width: 300px; }
    .user-email { display: none; }
  }

  /* --- Dashboard Main --- */
  .dashboard-main {
    flex: 1;
    padding-block: var(--space-12) var(--space-16);
  }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .page-title {
    font-size: var(--text-3xl);
  }

  /* --- Empty State --- */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-5);
    padding: var(--space-16) 0;
    max-width: 480px;
    margin-inline: auto;
  }

  .empty-visual {
    opacity: 0.85;
  }

  .empty-title {
    font-size: var(--text-2xl);
  }

  .empty-body {
    font-size: var(--text-base);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  /* --- Tree Grid --- */
  .tree-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .tree-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6);
    background-color: var(--color-surface-container-lowest);
    border-radius: var(--radius-xl);
    border: 1px solid oklch(35% 0.01 30 / 15%);
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow var(--duration-fast) var(--ease-out-quint),
      transform var(--duration-fast) var(--ease-out-quint);
  }

  .tree-card:hover {
    box-shadow: var(--shadow-1);
    transform: translateY(-2px);
  }

  .tree-card-body {
    flex: 1;
    min-width: 0;
  }

  .tree-card-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-bottom: var(--space-1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tree-card-meta {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .tree-card-open {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>

</style>

<script define:vars={{ treeId }}>
  import * as d3 from 'd3';
  import { getCurrentUser, userHasAccess } from '../../../lib/store';

  // Auth check
  if (!getCurrentUser() || !userHasAccess(treeId, getCurrentUser().id)) {
    window.location.href = '/auth/magic-link';
  }

  // Relationships data for panel family links (fetched client-side)
  let RELS: { relationships: any[] } = { relationships: [] };
  let MEMBERS: { list: any[] } = { list: [] };
  let TREE: { id: string; rootId: string | null } = { id: treeId, rootId: null };

  // Update page title and heading with tree name
  async function updateTreeInfo() {
    try {
      const res = await fetch(`/api/trees/${treeId}`);
      if (res.ok) {
        const tree = await res.json();
        TREE.rootId = tree.root_person_id;
        document.title = `${tree.name} — Big Family Tree`;
        const heading = document.getElementById('tree-heading');
        if (heading) heading.textContent = tree.name;
      }
    } catch {}
  }

  // Fetch graph data
  async function fetchGraph() {
    try {
      const res = await fetch(`/api/trees/${treeId}/graph`);
      if (res.ok) {
        const data = await res.json();
        MEMBERS.list = data.members || [];
        RELS.relationships = data.relationships || [];
        TREE.rootId = data.root_person_id;
      }
    } catch {}
  }

  interface Member {
    id: string;
    first_name: string;
    last_name: string;
    birth_date: string | null;
    death_date: string | null;
    gender: string | null;
    birth_place: string | null;
    location: string | null;
    occupation: string | null;
    bio: string | null;
    email: string | null;
    phone: string | null;
    profile_photo_url: string | null;
    is_root: boolean;
    last_edited_by: string | null;
    last_edited_at: string | null;
  }

  const panel = document.getElementById('profile-panel')!;
  const backdrop = document.getElementById('panel-backdrop')!;
  const panelBody = document.getElementById('panel-body')!;
  const panelClose = document.getElementById('panel-close')!;

  let currentMemberId: string | null = null;

  function formatDate(iso: string | null): string {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function getRelationshipLabel(rel: any, memberId: string): string {
    if (rel.person_a_id === memberId) {
      if (rel.relationship_type === 'spouse') return 'Spouse';
      if (rel.relationship_type === 'parent_child') {
        const other = MEMBERS.list.find((m: Member) => m.id === rel.person_b_id);
        return other ? `${other.first_name} is their child` : 'Child';
      }
      if (rel.relationship_type === 'step_sibling') return 'Step sibling';
    }
    if (rel.person_b_id === memberId) {
      if (rel.relationship_type === 'spouse') return 'Spouse';
      if (rel.relationship_type === 'parent_child') {
        const other = MEMBERS.list.find((m: Member) => m.id === rel.person_a_id);
        return other ? `${other.first_name} is their parent` : 'Parent';
      }
      if (rel.relationship_type === 'step_sibling') return 'Step sibling';
    }
    return rel.relationship_type;
  }

  async function openPanel(memberId: string) {
    currentMemberId = memberId;

    panel.hidden = false;
    backdrop.hidden = false;
    document.body.style.overflow = 'hidden';

    panelBody.innerHTML = `
      <div class="panel-loading">
        <div class="skeleton-avatar"></div>
        <div class="skeleton-line skeleton-line-lg"></div>
        <div class="skeleton-line"></div>
        <div class="skeleton-line"></div>
      </div>
    `;

    try {
      const res = await fetch(`/api/trees/${treeId}/members/${memberId}`, {
        credentials: 'include',
      });

      if (!res.ok) throw new Error('Failed to load');

      const member: Member & { last_editor_email?: string } = await res.json();

      const vitalParts: string[] = [];
      if (member.birth_date) vitalParts.push(`Born ${formatDate(member.birth_date)}`);
      if (member.birth_place) vitalParts.push(`in ${member.birth_place}`);
      if (member.death_date) vitalParts.push(`Died ${formatDate(member.death_date)}`);

      const vitalText = vitalParts.join(' ') + (vitalParts.length > 0 ? '' : 'Dates unknown');

      const locationLine = member.location
        ? `<p class="panel-field"><span class="panel-field-label">Location</span>${escapeHtml(member.location)}</p>`
        : '';
      const occupationLine = member.occupation
        ? `<p class="panel-field"><span class="panel-field-label">Occupation</span>${escapeHtml(member.occupation)}</p>`
        : '';
      const bioLine = member.bio
        ? `<div class="panel-bio"><span class="panel-field-label">About</span><div class="panel-bio-text">${escapeHtml(member.bio)}</div></div>`
        : '';

      // Family links — group by type
      const memberRels = RELS.relationships.filter((r: any) =>
        r.person_a_id === memberId || r.person_b_id === memberId
      );

      // Separate spouses, parents, children, siblings
      const spouses = memberRels.filter((r: any) => r.relationship_type === 'spouse');
      const parents = memberRels.filter((r: any) => r.relationship_type === 'parent_child' && r.person_b_id === memberId);
      const children = memberRels.filter((r: any) => r.relationship_type === 'parent_child' && r.person_a_id === memberId);
      const siblings = memberRels.filter((r: any) => r.relationship_type === 'step_sibling');

      function buildRelItems(rels: any[], getOtherId: (rel: any) => string, roleLabel: string, extraBadge?: (rel: any) => string) {
        if (rels.length === 0) return '';
        return rels.map((rel: any) => {
          const otherId = getOtherId(rel);
          const other = MEMBERS.list.find((m: Member) => m.id === otherId);
          if (!other) return '';
          const badge = extraBadge ? extraBadge(rel) : '';
          return `
            <button class="family-link" data-member-id="${other.id}">
              <span class="family-link-avatar">${other.first_name[0]}${other.last_name[0]}</span>
              <span class="family-link-info">
                <span class="family-link-name">${other.first_name} ${other.last_name}</span>
                <span class="family-link-role">${roleLabel}${badge ? ` · ${badge}` : ''}</span>
              </span>
            </button>`;
        }).join('');
      }

      const spouseSection = spouses.length > 0
        ? `<div class="panel-rel-group">
            <p class="panel-rel-group-label">Spouse${spouses.length > 1 ? 's' : ''}</p>
            <div class="panel-rel-items">${buildRelItems(spouses, (rel) => rel.person_a_id === memberId ? rel.person_b_id : rel.person_a_id, 'Spouse', (rel) => rel.is_primary ? 'Primary' : '')}</div>
           </div>`
        : '';

      const parentSection = parents.length > 0
        ? `<div class="panel-rel-group">
            <p class="panel-rel-group-label">Parents</p>
            <div class="panel-rel-items">${buildRelItems(parents, (rel) => rel.person_a_id === memberId ? rel.person_b_id : rel.person_a_id, 'Parent')}</div>
           </div>`
        : '';

      const childSection = children.length > 0
        ? `<div class="panel-rel-group">
            <p class="panel-rel-group-label">Children</p>
            <div class="panel-rel-items">${buildRelItems(children, (rel) => rel.person_b_id === memberId ? rel.person_a_id : rel.person_b_id, 'Child')}</div>
           </div>`
        : '';

      const siblingSection = siblings.length > 0
        ? `<div class="panel-rel-group">
            <p class="panel-rel-group-label">Step-siblings</p>
            <div class="panel-rel-items">${buildRelItems(siblings, (rel) => rel.person_a_id === memberId ? rel.person_b_id : rel.person_a_id, 'Step-sibling')}</div>
           </div>`
        : '';

      const hasFamilyLinks = spouseSection || parentSection || childSection || siblingSection;
      const familyLinksHtml = hasFamilyLinks
        ? spouseSection + parentSection + childSection + siblingSection
        : '<p class="panel-empty">No family links yet</p>';

      panelBody.innerHTML = `
        <div class="panel-profile-header">
          <div class="panel-avatar">
            ${member.profile_photo_url
              ? `<img src="${member.profile_photo_url}" alt="Profile photo of ${member.first_name} ${member.last_name}" class="panel-photo" />`
              : `<span class="panel-initials">${member.first_name[0]}${member.last_name[0]}</span>`
            }
          </div>
          <h2 class="panel-name">${member.first_name} ${member.last_name}</h2>
          ${member.is_root ? '<span class="panel-root-badge">Root ancestor</span>' : ''}
          <p class="panel-vitals">${vitalText}</p>
        </div>

        <div class="panel-section">
          ${locationLine}
          ${occupationLine}
        </div>

        ${bioLine}

        <div class="panel-section">
          <div class="panel-section-header">
            <h3 class="panel-section-title">Family</h3>
            ${isAdmin ? `<button class="panel-add-rel-btn" id="panel-add-rel-btn" data-member-id="${memberId}">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/>
              </svg>
              Add
            </button>` : ''}
          </div>
          ${familyLinksHtml}
        </div>

        <div class="panel-section panel-meta">
          ${member.last_edited_at
            ? `<p class="panel-edit-info">Last edited ${formatDate(member.last_edited_at)}</p>`
            : ''}
          <a href="/tree/${treeId}/members/${memberId}/edit" class="btn btn-outline btn-sm">
            Edit member
          </a>
        </div>
      `;

      // Family link click delegation
      panelBody.querySelectorAll('.family-link').forEach(link => {
        link.addEventListener('click', () => {
          const id = (link as HTMLElement).dataset.memberId;
          if (id) openPanel(id);
        });
      });

      // Add relationship button in panel
      const addRelBtn = document.getElementById('panel-add-rel-btn');
      if (addRelBtn) {
        addRelBtn.addEventListener('click', () => {
          const memberIdForRel = addRelBtn.dataset.memberId;
          if (memberIdForRel) openRelModal(undefined, memberIdForRel);
        });
      }

    } catch {
      panelBody.innerHTML = `
        <div class="panel-error">
          <p>Failed to load member details.</p>
          <button class="btn btn-ghost btn-sm" onclick="window.location.reload()">Retry</button>
        </div>
      `;
    }
  }

  function closePanel() {
    panel.hidden = true;
    backdrop.hidden = true;
    document.body.style.overflow = '';
    currentMemberId = null;
    // Deselect tree node
    selectedNodeId = null;
    updateTreeSelection();
  }

  backdrop.addEventListener('click', closePanel);
  panelClose.addEventListener('click', closePanel);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && currentMemberId) closePanel();
  });

  // ==============================
  // Relationship Creation Modal
  // ==============================

  // Toast helper
  function showToast(message: string, duration = 3500) {
    const existing = document.getElementById('app-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.id = 'app-toast';
    toast.className = 'app-toast';
    toast.textContent = message;
    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);padding:12px 20px;background:var(--color-inverse-surface);color:var(--color-inverse-on-surface);border-radius:9999px;font-size:14px;font-weight:500;z-index:9999;box-shadow:var(--shadow-2);transition:opacity 0.3s;opacity:1;';
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, duration);
  }

  // Modal state
  let relStep = 1;
  let relType: string | null = null;
  let relPersonA: string | null = null;
  let relPersonB: string | null = null;
  let relDragSource: string | null = null;

  const relModal = document.getElementById('rel-modal')!;
  const relModalBackdrop = document.getElementById('rel-modal-backdrop')!;
  const relModalClose = document.getElementById('rel-modal-close')!;
  const relNextBtn = document.getElementById('rel-next-btn') as HTMLButtonElement;
  const relBackBtn = document.getElementById('rel-back-btn') as HTMLButtonElement;
  const relCreateBtn = document.getElementById('rel-create-btn') as HTMLButtonElement;
  const relError = document.getElementById('rel-error')!;
  const openRelModalBtn = document.getElementById('open-rel-modal-btn') as HTMLButtonElement;

  function resetRelModal() {
    relStep = 1;
    relType = null;
    relPersonA = null;
    relPersonB = null;
    relDragSource = null;
    relError.hidden = true;
    updateRelStepUI();
    // Reset type selection
    document.querySelectorAll('.rel-type-btn').forEach(b => b.classList.remove('selected'));
    // Clear person selections
    relPersonA = null;
    relPersonB = null;
    // Reset form fields
    (document.getElementById('marriage-date') as HTMLInputElement).value = '';
    (document.getElementById('is-primary-check') as HTMLInputElement).checked = false;
    (document.getElementById('end-relationship-check') as HTMLInputElement).checked = false;
    (document.getElementById('divorce-date') as HTMLInputElement).value = '';
    (document.getElementById('ended-reason') as HTMLSelectElement).value = '';
    (document.getElementById('is-adopted-check') as HTMLInputElement).checked = false;
    document.getElementById('ended-details')!.hidden = true;
  }

  function openRelModal(preselectedType?: string, preselectedPersonA?: string) {
    resetRelModal();
    relModal.hidden = false;
    relNextBtn.hidden = false;
    relBackBtn.hidden = true;
    relCreateBtn.hidden = true;
    if (preselectedType) {
      relType = preselectedType;
      document.querySelector(`.rel-type-btn[data-type="${preselectedType}"]`)?.classList.add('selected');
      goToRelStep(2);
    }
    if (preselectedPersonA) {
      relPersonA = preselectedPersonA;
    }
  }

  function closeRelModal() {
    relModal.hidden = true;
    resetRelModal();
  }

  function goToRelStep(step: number) {
    relStep = step;
    updateRelStepUI();
  }

  function updateRelStepUI() {
    // Hide all steps
    for (let i = 1; i <= 4; i++) {
      const stepEl = document.getElementById(`rel-step-${i}`);
      if (stepEl) stepEl.hidden = i !== relStep;
    }

    // Update step indicator
    document.querySelectorAll('.rel-step').forEach(el => {
      const stepNum = parseInt(el.dataset.step ?? '0');
      el.classList.toggle('active', stepNum === relStep);
    });

    // Step-specific content population
    if (relStep === 2) {
      populatePersonList('rel-person-a-list', relPersonA);
    } else if (relStep === 3) {
      populatePersonList('rel-person-b-list', relPersonB);
    } else if (relStep === 4) {
      updateDetailsSection();
    }

    // Button visibility
    relBackBtn.hidden = relStep <= 2;
    relNextBtn.hidden = relStep >= 3;
    relCreateBtn.hidden = relStep !== 4;
    relNextBtn.disabled = !canProceed();
    relError.hidden = true;
  }

  function canProceed(): boolean {
    if (relStep === 2) return !!relPersonA;
    if (relStep === 3) return !!relPersonB;
    return true;
  }

  function populatePersonList(listId: string, selectedId: string | null) {
    const listEl = document.getElementById(listId)!;
    const excludeId = listId === 'rel-person-b-list' ? relPersonA : null;
    const selected = listId === 'rel-person-a-list' ? relPersonA : relPersonB;

    listEl.innerHTML = MEMBERS.list.map((m: Member) => {
      const isDisabled = excludeId === m.id;
      const isSelected = selected === m.id;
      const dates = m.birth_date
        ? `b. ${new Date(m.birth_date).getFullYear()}`
        : '';
      return `
        <button type="button" class="rel-person-item ${isDisabled ? 'disabled' : ''} ${isSelected ? 'selected' : ''}"
          data-member-id="${m.id}" ${isDisabled ? 'disabled' : ''}>
          <div class="rel-person-avatar">${m.first_name[0]}${m.last_name[0]}</div>
          <div class="rel-person-info">
            <div class="rel-person-name">${m.first_name} ${m.last_name}</div>
            ${dates ? `<div class="rel-person-dates">${dates}</div>` : ''}
          </div>
        </button>
      `;
    }).join('');

    listEl.querySelectorAll('.rel-person-item:not(.disabled)').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.memberId!;
        if (listId === 'rel-person-a-list') {
          relPersonA = id;
        } else {
          relPersonB = id;
        }
        updateRelStepUI();
      });
    });
  }

  function updateDetailsSection() {
    const spouseDetails = document.getElementById('spouse-details')!;
    const parentChildDetails = document.getElementById('parent-child-details')!;
    const isPrimaryWrap = document.getElementById('is-primary-wrap')!;

    spouseDetails.hidden = relType !== 'spouse';
    parentChildDetails.hidden = relType !== 'parent_child';

    // For spouse: check if there's already a primary spouse for personA
    if (relType === 'spouse' && relPersonA) {
      const existingPrimary = RELS.relationships.find((r: any) =>
        r.relationship_type === 'spouse' &&
        (r.person_a_id === relPersonA || r.person_b_id === relPersonA) &&
        r.is_primary === true
      );
      isPrimaryWrap.hidden = !existingPrimary;
    }

    // End relationship toggle
    const endCheck = document.getElementById('end-relationship-check') as HTMLInputElement;
    const endedDetails = document.getElementById('ended-details')!;
    endCheck.onchange = () => { endedDetails.hidden = !endCheck.checked; };
    endedDetails.hidden = true;
    endCheck.checked = false;
  }

  // Event listeners
  if (openRelModalBtn) {
    openRelModalBtn.addEventListener('click', () => openRelModal());
  }
  relModalBackdrop.addEventListener('click', closeRelModal);
  relModalClose.addEventListener('click', closeRelModal);

  relNextBtn.addEventListener('click', () => {
    if (relStep === 1 && relType) goToRelStep(2);
    else if (relStep === 2) goToRelStep(3);
    else if (relStep === 3) goToRelStep(4);
  });

  relBackBtn.addEventListener('click', () => {
    if (relStep > 1) goToRelStep(relStep - 1);
  });

  // Type buttons
  document.querySelectorAll('.rel-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.rel-type-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      relType = (btn as HTMLElement).dataset.type!;
      relNextBtn.disabled = false;
    });
  });

  relCreateBtn.addEventListener('click', async () => {
    relCreateBtn.disabled = true;
    relError.hidden = true;

    const payload: Record<string, any> = {
      relationship_type: relType,
      person_a_id: relPersonA,
      person_b_id: relPersonB,
    };

    if (relType === 'spouse') {
      const marriageDate = (document.getElementById('marriage-date') as HTMLInputElement).value;
      if (marriageDate) payload.marriage_date = marriageDate;

      const isPrimaryCheck = (document.getElementById('is-primary-check') as HTMLInputElement).checked;
      if (isPrimaryCheck) payload.is_primary = true;

      const endCheck = (document.getElementById('end-relationship-check') as HTMLInputElement).checked;
      if (endCheck) {
        payload.ended_reason = (document.getElementById('ended-reason') as HTMLSelectElement).value || null;
        payload.divorce_date = (document.getElementById('divorce-date') as HTMLInputElement).value || null;
      }
    }

    if (relType === 'parent_child') {
      const adoptedCheck = (document.getElementById('is-adopted-check') as HTMLInputElement).checked;
      if (adoptedCheck) payload.is_adopted = true;
    }

    try {
      const res = await fetch(`/api/trees/${treeId}/relationships`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) {
        relError.textContent = data.error || 'Failed to add relationship';
        relError.hidden = false;
      } else {
        RELS.relationships.push(data);
        showToast('Relationship added');
        closeRelModal();
        // Refresh panel if open
        if (currentMemberId) openPanel(currentMemberId);
      }
    } catch {
      relError.textContent = 'Failed to add relationship. Please try again.';
      relError.hidden = false;
    } finally {
      relCreateBtn.disabled = false;
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !relModal.hidden) closeRelModal();
  });

  // ==========================================================
  // D3 Tree Visualization
  // ==========================================================

  // Check for D3 container
  const svgWrapper = document.getElementById('tree-svg-wrapper');

  // Initialize data and tree
  async function init() {
    await updateTreeInfo();
    await fetchGraph();
    if (svgWrapper) {
      initTreeVisualization();
    }
  }
  init();


  async function initTreeVisualization() {
    const svg = d3.select('#tree-svg');
    const wrapper = svgWrapper!;

    // Build graph data
    interface GraphNode extends d3.SimulationNodeDatum {
      id: string;
      first_name: string;
      last_name: string;
      birth_date: string | null;
      death_date: string | null;
      profile_photo_url: string | null;
      is_root: boolean;
      gender: string | null;
      _children?: GraphNode[];
      _collapsed?: boolean;
      _childCount?: number;
    }

    interface GraphLink extends d3.SimulationLinkDatum<GraphNode> {
      relationship_type: string;
      is_primary?: boolean;
    }

    const nodes: GraphNode[] = MEMBERS.list.map(m => ({
      id: m.id,
      first_name: m.first_name,
      last_name: m.last_name,
      birth_date: m.birth_date,
      death_date: m.death_date,
      profile_photo_url: m.profile_photo_url,
      is_root: m.is_root,
      gender: m.gender,
    }));

    const links: GraphLink[] = RELS.relationships.map(r => ({
      source: r.person_a_id,
      target: r.person_b_id,
      relationship_type: r.relationship_type,
      is_primary: r.is_primary,
    }));

    // Build parent-child hierarchy
    // For each node, find children (person_a is parent of person_b in parent_child rel)
    const childrenByParent = new Map<string, string[]>();
    const parentByChild = new Map<string, string>();
    const spousePairs = new Set<string>();

    RELS.relationships.forEach(r => {
      if (r.relationship_type === 'parent_child') {
        const existing = childrenByParent.get(r.person_a_id) || [];
        existing.push(r.person_b_id);
        childrenByParent.set(r.person_a_id, existing);
        parentByChild.set(r.person_b_id, r.person_a_id);
      } else if (r.relationship_type === 'spouse') {
        // Store as unordered pair
        const pair = [r.person_a_id, r.person_b_id].sort().join('|');
        spousePairs.add(pair);
      }
    });

    // Build hierarchy tree from root
    function buildHierarchy(rootId: string | null): GraphNode | null {
      if (!rootId) {
        // Find a root member
        const rootNode = nodes.find(n => n.is_root);
        if (!rootNode && nodes.length > 0) {
          // Use first member as root
          return buildTree(nodes[0].id);
        }
        return rootNode ? buildTree(rootId) : null;
      }
      return buildTree(rootId);
    }

    function buildTree(rootId: string): GraphNode | null {
      const root = nodes.find(n => n.id === rootId);
      if (!root) return null;

      function attach(node: GraphNode): GraphNode {
        const childIds = childrenByParent.get(node.id) || [];
        const children = childIds
          .map(id => nodes.find(n => n.id === id))
          .filter(Boolean) as GraphNode[];
        if (children.length > 0) {
          node._children = children.map(c => attach(c));
          node._childCount = countDescendants(node);
        }
        return node;
      }

      return attach(root);
    }

    function countDescendants(node: GraphNode): number {
      if (!node._children || node._children.length === 0) return 0;
      return node._children.length + node._children.reduce((sum, c) => sum + countDescendants(c), 0);
    }

    function buildSubtree(rootId: string): GraphNode | null {
      const root = nodes.find(n => n.id === rootId);
      if (!root) return null;

      function attach(node: GraphNode): GraphNode {
        const childIds = childrenByParent.get(node.id) || [];
        const children = childIds
          .map(id => nodes.find(n => n.id === id))
          .filter(Boolean) as GraphNode[];
        if (children.length > 0) {
          node._children = children.map(c => attach(c));
          node._childCount = countDescendants(node);
        }
        return node;
      }

      return attach({ ...root });
    }

    // Get initial root from tree root_person_id
    let hierarchyRoot = buildHierarchy(TREE.rootId);

    // If still no root, use first node
    if (!hierarchyRoot && nodes.length > 0) {
      hierarchyRoot = buildTree(nodes[0].id);
    }

    // Tree dimensions
    const NODE_R = 28;
    const LINK_DIST = 110;

    // Setup SVG with zoom/pan
    const width = wrapper.clientWidth;
    const height = wrapper.clientHeight;

    svg.attr('viewBox', `0 0 ${width} ${height}`);

    const g = svg.append('g').attr('class', 'tree-g');

    // Zoom behavior
    const zoom = d3.zoom<SVGSVGElement, unknown>()
      .scaleExtent([0.15, 3])
      .on('zoom', (event) => {
        g.attr('transform', event.transform);
        currentZoom = event.transform.k;
      });

    svg.call(zoom);
    svg.on('dblclick.zoom', null); // Disable double-click zoom

    let currentZoom = 1;

    // Pan is handled by zoom's built-in drag behavior on the SVG
    svg.style('cursor', 'grab');

    let selectedNodeId: string | null = null;
    let deepLinkTimeout: ReturnType<typeof setTimeout> | null = null;
    let filteredRootId: string | null = null;
    let allNodes: GraphNode[] = [];

    function updateTreeSelection() {
      g.selectAll('.tree-node-group').each(function(d: any) {
        const el = d3.select(this);
        const isSelected = d.id === selectedNodeId;
        el.classed('selected', isSelected);
        el.select('.tree-node-ring')
          .attr('stroke-width', isSelected ? 3 : (d.is_root ? 2.5 : 0));
      });
    }

    // Render tree
    function renderTree(rootNode: GraphNode) {
      g.selectAll('*').remove();

      // Create radial tree layout
      const treeLayout = d3.tree<GraphNode>()
        .nodeSize([NODE_R * 2.5, NODE_R * 3])
        .separation((a, b) => a.parent === b.parent ? 1.2 : 1.8);

      // Convert hierarchy to d3 hierarchy
      const d3Root = d3.hierarchy(rootNode, (d) => {
        if (d._collapsed) return [];
        return d._children || [];
      });

      const treeData = treeLayout(d3Root);
      const linkData = treeData.links();
      const nodeData = treeData.descendants();

      // Center the tree
      const cx = width / 2;
      const cy = height / 2;

      // Update positions to be centered
      nodeData.forEach(d => {
        d.x = cx;
        d.y = cy;
      });

      // Create force simulation for radial layout
      const simulation = d3.forceSimulation<GraphNode>(nodeData)
        .force('link', d3.forceLink<GraphNode, d3.HierarchyLink<GraphNode>>(linkData)
          .id(d => d.id)
          .distance(LINK_DIST)
          .strength(0.8))
        .force('charge', d3.forceManyBody().strength(-200))
        .force('center', d3.forceCenter(cx, cy))
        .force('collision', d3.forceCollide(NODE_R * 2))
        .alpha(0.5)
        .alphaDecay(0.02);

      // Draw links first (excluding spouse links - those are drawn separately)
      const linkGroup = g.append('g').attr('class', 'links');

      // Filter out spouse links - they are drawn with curves in spouse group
      const treeOnlyLinks = linkData.filter(d => {
        const rel = RELS.relationships.find(r =>
          (r.person_a_id === (d.source as GraphNode).id && r.person_b_id === (d.target as GraphNode).id) ||
          (r.person_a_id === (d.target as GraphNode).id && r.person_b_id === (d.source as GraphNode).id)
        );
        return rel?.relationship_type !== 'spouse';
      });

      linkGroup.selectAll('.tree-link')
        .data(treeOnlyLinks)
        .join('line')
        .attr('class', 'tree-link')
        .attr('x1', d => (d.source as d3.SimulationNodeDatum).x!)
        .attr('y1', d => (d.source as d3.SimulationNodeDatum).y!)
        .attr('x2', d => (d.target as d3.SimulationNodeDatum).x!)
        .attr('y2', d => (d.target as d3.SimulationNodeDatum).y!);

      // Draw nodes
      const nodeGroup = g.append('g').attr('class', 'nodes');

      const nodeGs = nodeGroup.selectAll('.tree-node-group')
        .data(nodeData, (d: any) => d.data.id)
        .join('g')
        .attr('class', d => {
          let cls = 'tree-node-group';
          if (d.data.is_root) cls += ' tree-node-root';
          return cls;
        })
        .attr('transform', d => `translate(${d.x},${d.y})`)
        .style('cursor', 'pointer');

      // Avatar circle
      nodeGs.append('circle')
        .attr('class', 'tree-node-avatar')
        .attr('r', NODE_R)
        .attr('fill', d => {
          if (d.data.profile_photo_url) return 'var(--color-surface-container-lowest)';
          const gender = d.data.gender;
          if (gender === 'male') return 'var(--color-primary-fixed-dim)';
          if (gender === 'female') return 'var(--color-secondary-fixed-dim)';
          return 'var(--color-tertiary-fixed-dim)';
        })
        .attr('stroke', d => d.data.is_root ? 'var(--color-secondary)' : 'none')
        .attr('stroke-width', d => d.data.is_root ? 2.5 : 0)
        .attr('stroke-dasharray', d => d.data.is_root ? '4 2' : '');

      // Selection ring
      nodeGs.append('circle')
        .attr('class', 'tree-node-ring')
        .attr('r', NODE_R + 4)
        .attr('fill', 'none')
        .attr('stroke', 'var(--color-primary)')
        .attr('stroke-width', 0);

      // Photo or initials
      nodeGs.each(function(d: d3.HierarchyPointNode<GraphNode>) {
        const node = d3.select(this);
        if (d.data.profile_photo_url) {
          // Clip path for photo
          const clipId = `clip-${d.data.id}`;
          node.append('clipPath')
            .attr('id', clipId)
            .append('circle')
            .attr('r', NODE_R - 2);

          node.append('image')
            .attr('href', d.data.profile_photo_url)
            .attr('x', -NODE_R + 2)
            .attr('y', -NODE_R + 2)
            .attr('width', (NODE_R - 2) * 2)
            .attr('height', (NODE_R - 2) * 2)
            .attr('clip-path', `url(#${clipId})`)
            .attr('preserveAspectRatio', 'xMidYMid slice');
        } else {
          node.append('text')
            .attr('class', 'tree-node-initials')
            .attr('text-anchor', 'middle')
            .attr('dominant-baseline', 'central')
            .text(`${d.data.first_name[0]}${d.data.last_name[0]}`);
        }
      });

      // Name label
      nodeGs.append('text')
        .attr('class', 'tree-node-name')
        .attr('text-anchor', 'middle')
        .attr('y', NODE_R + 14)
        .text(d => `${d.data.first_name} ${d.data.last_name[0]}.`);

      // Dates label (if has dates)
      nodeGs.filter(d => d.data.birth_date || d.data.death_date)
        .append('text')
        .attr('class', 'tree-node-dates')
        .attr('text-anchor', 'middle')
        .attr('y', NODE_R + 26)
        .text(d => {
          const parts: string[] = [];
          if (d.data.birth_date) parts.push(new Date(d.data.birth_date).getFullYear().toString());
          if (d.data.death_date) parts.push(new Date(d.data.death_date).getFullYear().toString());
          return parts.join('–');
        });

      // Collapse/expand button (if has children)
      nodeGs.filter(d => (d.data._children && d.data._children.length > 0) || d.data._collapsed)
        .append('g')
        .attr('class', 'tree-collapse-g')
        .attr('transform', `translate(${NODE_R + 8}, ${-NODE_R - 8})`)
        .each(function(d: d3.HierarchyPointNode<GraphNode>) {
          const btn = d3.select(this);
          btn.append('circle')
            .attr('r', 10)
            .attr('fill', 'var(--color-surface-container-lowest)')
            .attr('stroke', 'var(--color-outline-variant)')
            .attr('stroke-width', 1.5);
          btn.append('text')
            .attr('text-anchor', 'middle')
            .attr('dominant-baseline', 'central')
            .attr('font-size', '10px')
            .attr('fill', 'var(--color-on-surface-variant)')
            .text(d.data._collapsed ? `+${d.data._childCount}` : '−');
        })
        .on('click', (event, d: d3.HierarchyPointNode<GraphNode>) => {
          event.stopPropagation();
          toggleCollapse(d.data.id);
        });

      // Spouse links (draw as curved lines separately)
      const spouseGroup = g.append('g').attr('class', 'spouse-links');
      const spouseSet = new Set<string>();
      const spousePaths: { src: d3.HierarchyPointNode<GraphNode>; tgt: d3.HierarchyPointNode<GraphNode> }[] = [];

      RELS.relationships.forEach(r => {
        if (r.relationship_type === 'spouse') {
          const pair = [r.person_a_id, r.person_b_id].sort().join('|');
          if (!spouseSet.has(pair)) {
            spouseSet.add(pair);
            const src = nodeData.find(n => n.data.id === r.person_a_id);
            const tgt = nodeData.find(n => n.data.id === r.person_b_id);
            if (src && tgt) {
              spousePaths.push({ src, tgt });
              const mx = ((src.x || 0) + (tgt.x || 0)) / 2;
              const my = ((src.y || 0) + (tgt.y || 0)) / 2 - 40; // Curve upward
              spouseGroup.append('path')
                .attr('class', 'tree-link tree-link-spouse')
                .attr('d', `M ${src.x} ${src.y} Q ${mx} ${my} ${tgt.x} ${tgt.y}`);
            }
          }
        }
      });

      // Simulation tick
      simulation.on('tick', () => {
        linkGroup.selectAll('.tree-link')
          .attr('x1', d => (d.source as d3.SimulationNodeDatum).x!)
          .attr('y1', d => (d.source as d3.SimulationNodeDatum).y!)
          .attr('x2', d => (d.target as d3.SimulationNodeDatum).x!)
          .attr('y2', d => (d.target as d3.SimulationNodeDatum).y!);

        nodeGs.attr('transform', d => `translate(${d.x},${d.y})`);

        // Update spouse link paths
        spouseGroup.selectAll('.tree-link-spouse')
          .each(function(_, i) {
            const { src, tgt } = spousePaths[i];
            const mx = ((src.x || 0) + (tgt.x || 0)) / 2;
            const my = ((src.y || 0) + (tgt.y || 0)) / 2 - 40;
            d3.select(this).attr('d', `M ${src.x} ${src.y} Q ${mx} ${my} ${tgt.x} ${tgt.y}`);
          });
      });

      // Node click → open panel
      nodeGs.on('click', (event, d: d3.HierarchyPointNode<GraphNode>) => {
        event.stopPropagation();
        selectedNodeId = d.data.id;
        updateTreeSelection();
        enableFilterBtn(selectedNodeId);
        openPanel(d.data.id);
        centerOnNode(d.data.id);
        updateBreadcrumb(d.data.id);
        // Update URL hash for deep linking
        history.replaceState(null, '', `#person-${d.data.id}`);
      });

      // Force layout for non-hierarchy members (members not in tree)
      // Add orphan nodes
      const orphanNodes = nodes.filter(n => {
        return !nodeData.some(d => d.data.id === n.id);
      });

      if (orphanNodes.length > 0) {
        // Position orphans in a ring around center
        const orphanRadius = Math.min(width, height) * 0.35;
        orphanNodes.forEach((n, i) => {
          const angle = (i / orphanNodes.length) * 2 * Math.PI - Math.PI / 2;
          n.x = cx + orphanRadius * Math.cos(angle);
          n.y = cy + orphanRadius * Math.sin(angle);
        });

        // Add orphan nodes to simulation
        const allNodes = [...nodeData.map(d => d as GraphNode), ...orphanNodes];
        const orphanLinks = links.filter(l => {
          return orphanNodes.some(on => on.id === (typeof l.source === 'string' ? l.source : l.source.id)) ||
                 orphanNodes.some(on => on.id === (typeof l.target === 'string' ? l.target : l.target.id));
        });

        const orphanSim = d3.forceSimulation<GraphNode>(allNodes)
          .force('link', d3.forceLink<GraphNode, GraphLink>(orphanLinks)
            .id(d => d.id)
            .distance(LINK_DIST)
            .strength(0.3))
          .force('charge', d3.forceManyBody().strength(-100))
          .force('center', d3.forceCenter(cx, cy))
          .alpha(0.3)
          .alphaDecay(0.02);

        orphanSim.on('tick', () => {
          nodeGs.attr('transform', d => `translate(${d.x},${d.y})`);
        });
      }

      // Zoom controls
      const zoomInBtn = document.getElementById('zoom-in-btn');
      const zoomOutBtn = document.getElementById('zoom-out-btn');
      const zoomResetBtn = document.getElementById('zoom-reset-btn');

      if (zoomInBtn) {
        zoomInBtn.addEventListener('click', () => {
          svg.transition().duration(300).call(zoom.scaleBy, 1.4);
        });
      }
      if (zoomOutBtn) {
        zoomOutBtn.addEventListener('click', () => {
          svg.transition().duration(300).call(zoom.scaleBy, 0.7);
        });
      }
      if (zoomResetBtn) {
        zoomResetBtn.addEventListener('click', () => {
          svg.transition().duration(400).call(
            zoom.transform,
            d3.zoomIdentity.translate(width / 2, height / 2).scale(1).translate(-width / 2, -height / 2)
          );
        });
      }

      // Scroll wheel zoom
      svg.on('wheel', (event) => {
        event.preventDefault();
        const delta = event.deltaY > 0 ? 0.85 : 1.15;
        svg.transition().duration(200).call(zoom.scaleBy, delta);
      });

      // Mobile pinch zoom
      let lastPinchDist = 0;
      svg.node().addEventListener('touchmove', (event) => {
        if (event.touches.length === 2) {
          const dx = event.touches[0].clientX - event.touches[1].clientX;
          const dy = event.touches[0].clientY - event.touches[1].clientY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (lastPinchDist > 0) {
            const scale = dist / lastPinchDist;
            svg.call(zoom.scaleBy, scale);
          }
          lastPinchDist = dist;
          event.preventDefault();
        }
      }, { passive: false });

      svg.node().addEventListener('touchend', () => {
        lastPinchDist = 0;
      });

      // Collapse all button
      const collapseAllBtn = document.getElementById('collapse-all-btn');
      if (collapseAllBtn) {
        collapseAllBtn.addEventListener('click', () => {
          nodeGs.filter(d => (d.data._children && d.data._children.length > 0))
            .each(function(d: any) {
              d.data._collapsed = true;
            });
          renderTree(rootNode);
        });
      }

      // Branch filter buttons
      const filterBranchBtn = document.getElementById('filter-branch-btn') as HTMLButtonElement;
      const clearFilterBtn = document.getElementById('clear-filter-btn') as HTMLButtonElement;

      function enableFilterBtn(nodeId: string | null) {
        if (filterBranchBtn) {
          filterBranchBtn.disabled = !nodeId;
        }
      }

      function showClearFilterBtn() {
        if (clearFilterBtn) clearFilterBtn.hidden = false;
      }

      function hideClearFilterBtn() {
        if (clearFilterBtn) clearFilterBtn.hidden = true;
      }

      filterBranchBtn?.addEventListener('click', () => {
        if (selectedNodeId) {
          filteredRootId = selectedNodeId;
          showClearFilterBtn();
          // Re-render tree from selected node as root
          const filterRoot = nodes.find(n => n.id === selectedNodeId);
          if (filterRoot) {
            const filteredHierarchy = buildSubtree(selectedNodeId);
            if (filteredHierarchy) {
              renderTree(filteredHierarchy);
            }
          }
        }
      });

      clearFilterBtn?.addEventListener('click', () => {
        filteredRootId = null;
        hideClearFilterBtn();
        // Re-render full tree
        if (hierarchyRoot) {
          renderTree(hierarchyRoot);
        }
      });

      // Click on background to deselect
      svg.on('click', (event) => {
        if (event.target === svg.node()) {
          selectedNodeId = null;
          updateTreeSelection();
          updateBreadcrumb(null);
          history.replaceState(null, '', window.location.pathname);
        }
      });

      // Deep link: check hash on load
      const hash = window.location.hash;
      if (hash.startsWith('#person-')) {
        const personId = hash.replace('#person-', '');
        if (deepLinkTimeout) clearTimeout(deepLinkTimeout);
        deepLinkTimeout = setTimeout(() => {
          selectedNodeId = personId;
          updateTreeSelection();
          centerOnNode(personId);
          updateBreadcrumb(personId);
          openPanel(personId);
        }, 800);
      }

      // Toggle collapse helper
      window.toggleCollapse = function(nodeId: string) {
        const node = nodeData.find(d => d.data.id === nodeId);
        if (node) {
          node.data._collapsed = !node.data._collapsed;
          renderTree(rootNode);
        }
      };

      // Center on node
      function centerOnNode(nodeId: string) {
        const node = nodeData.find(d => d.data.id === nodeId);
        if (!node) return;

        const targetX = width / 2;
        const targetY = height / 2;
        const nodeX = node.x!;
        const nodeY = node.y!;

        const transform = d3.zoomIdentity
          .translate(targetX - nodeX, targetY - nodeY)
          .scale(currentZoom > 0.5 ? currentZoom : 1);

        svg.transition().duration(500).call(zoom.transform, transform);
      }

      // Update breadcrumb
      function getAncestors(nodeId: string): GraphNode[] {
        const ancestors: GraphNode[] = [];
        let current = nodeData.find(d => d.data.id === nodeId);
        while (current && current.parent) {
          ancestors.unshift(current.parent.data);
          current = current.parent;
        }
        return ancestors;
      }

      function updateBreadcrumb(nodeId: string | null) {
        const breadcrumb = document.getElementById('tree-breadcrumb');
        const breadcrumbList = document.getElementById('breadcrumb-list');
        if (!breadcrumb || !breadcrumbList) return;

        if (!nodeId) {
          breadcrumb.hidden = true;
          return;
        }

        breadcrumb.hidden = false;
        const ancestors = getAncestors(nodeId);
        const current = nodeData.find(d => d.data.id === nodeId)?.data;
        const path = [...ancestors, current].filter(Boolean) as GraphNode[];

        breadcrumbList.innerHTML = path.map((n, i) => {
          const isLast = i === path.length - 1;
          return `
            <li class="breadcrumb-item">
              <button class="breadcrumb-link ${isLast ? 'active' : ''}"
                      data-member-id="${n.id}"
                      type="button">
                <span class="breadcrumb-avatar">${n.first_name[0]}${n.last_name[0]}</span>
                <span>${n.first_name}</span>
              </button>
              ${!isLast ? '<span class="breadcrumb-sep" aria-hidden="true">›</span>' : ''}
            </li>
          `;
        }).join('');

        breadcrumbList.querySelectorAll('.breadcrumb-link').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.memberId;
            if (id) {
              selectedNodeId = id;
              updateTreeSelection();
              centerOnNode(id);
              updateBreadcrumb(id);
              openPanel(id);
              history.replaceState(null, '', `#person-${id}`);
            }
          });
        });
      }

      // Initial breadcrumb
      updateBreadcrumb(hierarchyRoot?.id || null);

      // Resize handler
      const resizeObserver = new ResizeObserver(() => {
        const w = wrapper.clientWidth;
        const h = wrapper.clientHeight;
        svg.attr('viewBox', `0 0 ${w} ${h}`);
        simulation.force('center', d3.forceCenter(w / 2, h / 2));
        simulation.alpha(0.1).restart();
      });
      resizeObserver.observe(wrapper);

      // Keyboard navigation
      let keyboardNodeIndex = -1;
      let focusedNodeId: string | null = null;

      function focusNode(nodeId: string | null) {
        focusedNodeId = nodeId;
        if (!nodeId) {
          keyboardNodeIndex = -1;
          svg.node()?.blur();
          return;
        }
        keyboardNodeIndex = nodeData.findIndex(d => d.data.id === nodeId);
        if (keyboardNodeIndex >= 0) {
          selectedNodeId = nodeId;
          updateTreeSelection();
          enableFilterBtn(nodeId);
          centerOnNode(nodeId);
          updateBreadcrumb(nodeId);
          history.replaceState(null, '', `#person-${nodeId}`);
        }
      }

      function getAdjacentNode(direction: 'up' | 'down' | 'left' | 'right'): string | null {
        if (nodeData.length === 0) return null;
        if (keyboardNodeIndex < 0 || keyboardNodeIndex >= nodeData.length) {
          return nodeData[0].data.id;
        }
        const current = nodeData[keyboardNodeIndex];
        const cx = current.x || 0;
        const cy = current.y || 0;

        // Find nearest node in direction
        let best: d3.HierarchyPointNode<GraphNode> | null = null;
        let bestDist = Infinity;

        nodeData.forEach((d, i) => {
          if (i === keyboardNodeIndex) return;
          const dx = (d.x || 0) - cx;
          const dy = (d.y || 0) - cy;
          let valid = false;
          let score = Infinity;

          if (direction === 'right' && dx > 20) { valid = true; score = Math.abs(dy) + dx * 0.5; }
          else if (direction === 'left' && dx < -20) { valid = true; score = Math.abs(dy) + Math.abs(dx) * 0.5; }
          else if (direction === 'down' && dy > 20) { valid = true; score = Math.abs(dx) + dy * 0.5; }
          else if (direction === 'up' && dy < -20) { valid = true; score = Math.abs(dx) + Math.abs(dy) * 0.5; }

          if (valid && score < bestDist) {
            bestDist = score;
            best = d;
          }
        });

        return best?.data.id || null;
      }

      document.addEventListener('keydown', (e) => {
        // Only handle when SVG wrapper is focused or no other input is focused
        const activeTag = document.activeElement?.tagName;
        if (['INPUT', 'TEXTAREA', 'SELECT'].includes(activeTag || '')) return;

        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          e.preventDefault();
          const dir = e.key === 'ArrowRight' ? 'right' : e.key === 'ArrowLeft' ? 'left' : e.key === 'ArrowDown' ? 'down' : 'up';
          const nextId = getAdjacentNode(dir);
          if (nextId) focusNode(nextId);
        } else if (e.key === 'Enter' || e.key === ' ') {
          if (focusedNodeId) {
            e.preventDefault();
            openPanel(focusedNodeId);
          }
        } else if (e.key === 'Escape') {
          if (currentMemberId) {
            closePanel();
          } else if (focusedNodeId) {
            focusNode(null);
            selectedNodeId = null;
            updateTreeSelection();
            updateBreadcrumb(null);
            history.replaceState(null, '', window.location.pathname);
          }
        } else if (e.key === 'Home') {
          e.preventDefault();
          if (nodeData.length > 0) focusNode(nodeData[0].data.id);
        } else if (e.key === 'End') {
          e.preventDefault();
          if (nodeData.length > 0) focusNode(nodeData[nodeData.length - 1].data.id);
        }
      });

      // Focus SVG wrapper when clicking on canvas
      svgWrapper.addEventListener('click', () => {
        if (focusedNodeId === null && selectedNodeId === null) {
          svgWrapper.focus();
        }
      });

      // Make SVG wrapper focusable for keyboard nav
      svgWrapper.addEventListener('focus', () => {
        if (!focusedNodeId && !selectedNodeId && nodeData.length > 0) {
          // Auto-focus first node when tabbing to canvas
        }
      });

      // Hide loading
      const loading = document.getElementById('tree-loading');
      if (loading) loading.hidden = true;
    }

    // Start rendering
    if (hierarchyRoot) {
      renderTree(hierarchyRoot);
    } else if (nodes.length > 0) {
      // No hierarchy - show all nodes in force layout
      renderFlatLayout();
    }

    function renderFlatLayout() {
      const svg = d3.select('#tree-svg');
      const g = svg.select('.tree-g') || svg.append('g');
      const w = wrapper.clientWidth;
      const h = wrapper.clientHeight;

      svg.attr('viewBox', `0 0 ${w} ${h}`);

      const zoom = d3.zoom<SVGSVGElement, unknown>()
        .scaleExtent([0.15, 3])
        .on('zoom', (event) => {
          g.attr('transform', event.transform);
        });

      svg.call(zoom);

      // Simple force layout for flat view
      interface FlatNode extends d3.SimulationNodeDatum {
        id: string;
        first_name: string;
        last_name: string;
        birth_date: string | null;
        death_date: string | null;
        profile_photo_url: string | null;
        is_root: boolean;
        gender: string | null;
      }

      const flatNodes: FlatNode[] = nodes.map(n => ({ ...n }));
      const flatLinks = links.map(l => ({
        source: typeof l.source === 'string' ? l.source : l.source.id,
        target: typeof l.target === 'string' ? l.target : l.target.id,
        relationship_type: l.relationship_type,
      }));

      const sim = d3.forceSimulation<FlatNode>(flatNodes)
        .force('link', d3.forceLink(flatLinks).id((d: any) => d.id).distance(120).strength(0.5))
        .force('charge', d3.forceManyBody().strength(-300))
        .force('center', d3.forceCenter(w / 2, h / 2))
        .force('collision', d3.forceCollide(50));

      const linkG = g.append('g').attr('class', 'flat-links');
      const nodeG = g.append('g').attr('class', 'flat-nodes');

      const linkEls = linkG.selectAll('.tree-link')
        .data(flatLinks)
        .join('line')
        .attr('class', 'tree-link')
        .attr('x1', d => flatNodes.find(n => n.id === (typeof d.source === 'object' ? d.source.id : d.source))?.x || 0)
        .attr('y1', d => flatNodes.find(n => n.id === (typeof d.source === 'object' ? d.source.id : d.source))?.y || 0)
        .attr('x2', d => flatNodes.find(n => n.id === (typeof d.target === 'object' ? d.target.id : d.target))?.x || 0)
        .attr('y2', d => flatNodes.find(n => n.id === (typeof d.target === 'object' ? d.target.id : d.target))?.y || 0);

      const nodeEls = nodeG.selectAll('.tree-node-group')
        .data(flatNodes)
        .join('g')
        .attr('class', 'tree-node-group')
        .call(d3.drag<any, FlatNode>()
          .on('start', function() { d3.select(this).raise(); })
          .on('drag', function(event, d) {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on('end', function(event, d) {
            d.fx = null;
            d.fy = null;
          }));

      nodeEls.append('circle')
        .attr('class', 'tree-node-avatar')
        .attr('r', NODE_R)
        .attr('fill', d => {
          if (d.profile_photo_url) return 'var(--color-surface-container-lowest)';
          if (d.gender === 'male') return 'var(--color-primary-fixed-dim)';
          if (d.gender === 'female') return 'var(--color-secondary-fixed-dim)';
          return 'var(--color-tertiary-fixed-dim)';
        });

      nodeEls.append('text')
        .attr('class', 'tree-node-initials')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .text(d => `${d.first_name[0]}${d.last_name[0]}`);

      nodeEls.append('text')
        .attr('class', 'tree-node-name')
        .attr('text-anchor', 'middle')
        .attr('y', NODE_R + 14)
        .text(d => `${d.first_name} ${d.last_name[0]}.`);

      nodeEls.on('click', (event, d) => {
        event.stopPropagation();
        selectedNodeId = d.id;
        updateFlatSelection();
        openPanel(d.id);
        centerOnFlatNode(d.id);
        history.replaceState(null, '', `#person-${d.id}`);
      });

      // Click on background to deselect
      svg.on('click', (event) => {
        if (event.target === svg.node()) {
          selectedNodeId = null;
          updateFlatSelection();
          history.replaceState(null, '', window.location.pathname);
        }
      });

      // Update flat selection visuals
      function updateFlatSelection() {
        nodeEls.classed('selected', (d: any) => d.id === selectedNodeId);
      }

      // Center on node in flat layout
      function centerOnFlatNode(nodeId: string) {
        const node = flatNodes.find(n => n.id === nodeId);
        if (!node) return;
        const transform = d3.zoomIdentity
          .translate(w / 2 - (node.x || 0), h / 2 - (node.y || 0))
          .scale(currentZoom > 0.5 ? currentZoom : 1);
        svg.transition().duration(500).call(zoom.transform, transform);
      }

      // Deep link: check hash on load in flat layout
      const flatHash = window.location.hash;
      if (flatHash.startsWith('#person-')) {
        const personId = flatHash.replace('#person-', '');
        if (deepLinkTimeout) clearTimeout(deepLinkTimeout);
        deepLinkTimeout = setTimeout(() => {
          selectedNodeId = personId;
          updateFlatSelection();
          centerOnFlatNode(personId);
          openPanel(personId);
        }, 800);
      }

      sim.on('tick', () => {
        linkEls
          .attr('x1', d => (d.source as FlatNode).x!)
          .attr('y1', d => (d.source as FlatNode).y!)
          .attr('x2', d => (d.target as FlatNode).x!)
          .attr('y2', d => (d.target as FlatNode).y!);

        nodeEls.attr('transform', d => `translate(${d.x},${d.y})`);
      });

      // Loading hide
      const loading = document.getElementById('tree-loading');
      if (loading) loading.hidden = true;

      // Zoom controls for flat
      const zoomInBtn = document.getElementById('zoom-in-btn');
      const zoomOutBtn = document.getElementById('zoom-out-btn');
      const zoomResetBtn = document.getElementById('zoom-reset-btn');
      if (zoomInBtn) zoomInBtn.addEventListener('click', () => svg.transition().duration(300).call(zoom.scaleBy, 1.4));
      if (zoomOutBtn) zoomOutBtn.addEventListener('click', () => svg.transition().duration(300).call(zoom.scaleBy, 0.7));
      if (zoomResetBtn) zoomResetBtn.addEventListener('click', () => svg.transition().duration(400).call(zoom.transform, d3.zoomIdentity));

      svg.on('wheel', (event) => {
        event.preventDefault();
        svg.transition().duration(200).call(zoom.scaleBy, event.deltaY > 0 ? 0.85 : 1.15);
      });
    }
  }
</script>


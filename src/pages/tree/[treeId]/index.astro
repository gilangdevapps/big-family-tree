---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Family Tree">
  <div class="tree-shell">
    <!-- Top Bar -->
    <header class="top-bar">
      <div class="container top-bar-inner">
        <div class="top-bar-left">
          <a href="/dashboard" class="nav-back" aria-label="Back to dashboard">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
              <path d="M12 4l-6 6 6 6"/>
            </svg>
          </a>
          <h1 class="tree-name" id="tree-heading">Loading…</h1>
        </div>
        <div class="top-bar-right">
          {true && (
            <>
              <a href={`/tree/${treeId}/members/new`} class="btn btn-primary btn-sm">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                  <line x1="8" y1="2" x2="8" y2="14"/>
                  <line x1="2" y1="8" x2="14" y2="8"/>
                </svg>
                Add member
              </a>
              <button type="button" class="btn btn-ghost btn-sm" id="open-rel-modal-btn" title="Add relationship">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                  <path d="M10 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4zM6 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM14 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
                  <path d="M10 8v1M8.5 9.5L9 10M10.5 9.5L10 10" stroke-linecap="round"/>
                </svg>
                Add relationship
              </button>
            </>
          )}
          <a href={`/tree/${treeId}/settings`} class="btn btn-ghost btn-sm" aria-label="Tree settings">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <circle cx="10" cy="10" r="3"/>
              <path d="M10 1v2M10 17v2M1 10h2M17 10h2M3.5 3.5l1.4 1.4M15.1 15.1l1.4 1.4M3.5 16.5l1.4-1.4M15.1 4.9l1.4-1.4"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Tree Canvas Area -->
    <main class="tree-canvas" id="tree-canvas">
      {isEmpty ? (
        <div class="empty-tree-state">
          <div class="empty-visual" aria-hidden="true">
            <svg width="140" height="140" viewBox="0 0 140 140" fill="none">
              <circle cx="70" cy="70" r="65" fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1.5" stroke-dasharray="6 5"/>
              <circle cx="70" cy="55" r="18" fill="var(--color-surface-container-high)"/>
              <circle cx="42" cy="100" r="12" fill="var(--color-surface-container-high)"/>
              <circle cx="98" cy="100" r="12" fill="var(--color-surface-container-high)"/>
              <line x1="70" y1="73" x2="42" y2="88" stroke="var(--color-secondary-fixed)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="70" y1="73" x2="98" y2="88" stroke="var(--color-secondary-fixed)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="42" y1="100" x2="98" y2="100" stroke="var(--color-secondary-fixed)" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h2 class="empty-title">This tree is waiting for roots</h2>
          <p class="empty-body">Add your first family member to get started. You can start from the oldest person you know, or add yourself as a starting point.</p>
          {true ? (
            <a href={`/tree/${treeId}/members/new`} class="btn btn-primary">
              Add your first member
            </a>
          ) : (
            <p class="empty-note">Only admins can add members. Ask the tree owner to add someone.</p>
          )}
        </div>
      ) : (
        <>
        <!-- Tree Toolbar -->
        <div class="tree-toolbar" id="tree-toolbar" role="toolbar" aria-label="Tree navigation">
          <div class="toolbar-group">
            <button type="button" class="toolbar-btn" id="zoom-in-btn" title="Zoom in" aria-label="Zoom in">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <circle cx="10" cy="10" r="7"/>
                <line x1="7" y1="10" x2="13" y2="10"/><line x1="10" y1="7" x2="10" y2="13"/>
              </svg>
            </button>
            <button type="button" class="toolbar-btn" id="zoom-out-btn" title="Zoom out" aria-label="Zoom out">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <circle cx="10" cy="10" r="7"/>
                <line x1="7" y1="10" x2="13" y2="10"/>
              </svg>
            </button>
            <button type="button" class="toolbar-btn" id="zoom-reset-btn" title="Reset view" aria-label="Reset view">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <path d="M3 10a7 7 0 1 0 7-7"/>
                <path d="M3 6v4h4"/>
              </svg>
            </button>
          </div>
          <div class="toolbar-separator" aria-hidden="true"></div>
          <div class="toolbar-group">
            <button type="button" class="toolbar-btn" id="collapse-all-btn" title="Collapse all branches" aria-label="Collapse all">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <path d="M4 8l6 5 6-5"/><line x1="10" y1="5" x2="10" y2="15"/>
              </svg>
            </button>
          </div>
          <div class="toolbar-separator" aria-hidden="true"></div>
          <div class="toolbar-group">
            <button type="button" class="toolbar-btn" id="filter-branch-btn" title="Filter to this branch" aria-label="Filter to this branch" disabled>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <path d="M3 6h14M6 6v8M14 6v3M14 13h-4"/>
                <path d="M10 9l4 3M14 9l-4 3"/>
              </svg>
            </button>
            <button type="button" class="toolbar-btn" id="clear-filter-btn" title="Show all" aria-label="Show all members" hidden>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <circle cx="10" cy="10" r="7"/>
                <path d="M7 10h6"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Breadcrumb -->
        <nav class="tree-breadcrumb" id="tree-breadcrumb" aria-label="Tree navigation" hidden>
          <ol class="breadcrumb-list" id="breadcrumb-list">
          </ol>
        </nav>

        <!-- D3 SVG Tree -->
        <div class="tree-svg-wrapper" id="tree-svg-wrapper" tabindex="0">
          <svg id="tree-svg" aria-label="Family tree visualization" role="img"></svg>
        </div>

        <!-- Loading overlay -->
        <div class="tree-loading" id="tree-loading" aria-live="polite" aria-label="Loading tree" hidden>
          <div class="tree-loading-inner">
            <div class="spinner"></div>
            <span>Building family tree…</span>
          </div>
        </div>
        </>
      )}
    </main>

    <!-- Profile Panel (slide-out) -->
    <div class="profile-panel-backdrop" id="panel-backdrop" hidden></div>
    <aside class="profile-panel" id="profile-panel" aria-label="Member profile" aria-modal="true" hidden>
      <div class="panel-header">
        <button class="panel-close" id="panel-close" aria-label="Close panel">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 5l10 10M15 5L5 15"/>
          </svg>
        </button>
      </div>
      <div class="panel-body" id="panel-body">
        <!-- Content loaded by JS -->
      </div>
    </aside>

    <!-- Relationship Creation Modal -->
    <div id="rel-modal" class="rel-modal" hidden role="dialog" aria-modal="true" aria-labelledby="rel-modal-title">
      <div class="rel-modal-backdrop" id="rel-modal-backdrop"></div>
      <div class="rel-modal-card">
        <div class="rel-modal-header">
          <h2 class="rel-modal-title" id="rel-modal-title">Add a relationship</h2>
          <button class="rel-modal-close" id="rel-modal-close" aria-label="Close">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 5l10 10M15 5L5 15"/>
            </svg>
          </button>
        </div>

        <!-- Step indicator -->
        <div class="rel-steps" id="rel-steps" aria-live="polite">
          <span class="rel-step active" data-step="1">1. Type</span>
          <span class="rel-step" data-step="2" hidden>2. First person</span>
          <span class="rel-step" data-step="3" hidden>3. Second person</span>
          <span class="rel-step" data-step="4" hidden>4. Details</span>
        </div>

        <!-- Step 1: Relationship type -->
        <div class="rel-step-content" id="rel-step-1">
          <p class="rel-step-desc">What kind of relationship?</p>
          <div class="rel-type-grid">
            <button type="button" class="rel-type-btn" data-type="spouse">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <path d="M14 6c-3.3 0-6 2.7-6 6s2.7 6 6 6 6-2.7 6-6-2.7-6-6-6z"/>
                <path d="M8 20l4-6 4 6"/>
                <path d="M6 12h4M18 12h4"/>
              </svg>
              <span class="rel-type-label">Spouse</span>
              <span class="rel-type-desc">Married or partner</span>
            </button>
            <button type="button" class="rel-type-btn" data-type="parent_child">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <circle cx="14" cy="8" r="4"/>
                <circle cx="7" cy="20" r="3"/>
                <circle cx="21" cy="20" r="3"/>
                <line x1="14" y1="12" x2="7" y2="17"/>
                <line x1="14" y1="12" x2="21" y2="17"/>
              </svg>
              <span class="rel-type-label">Parent–Child</span>
              <span class="rel-type-desc">Biological or adoptive</span>
            </button>
            <button type="button" class="rel-type-btn" data-type="step_sibling">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <path d="M8 10c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4"/>
                <path d="M16 18c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4"/>
                <path d="M8 14v4M16 14v4"/>
              </svg>
              <span class="rel-type-label">Step-sibling</span>
              <span class="rel-type-desc">Through remarriage</span>
            </button>
          </div>
        </div>

        <!-- Step 2: Person A -->
        <div class="rel-step-content" id="rel-step-2" hidden>
          <p class="rel-step-desc">Select the first person</p>
          <div class="rel-person-list" id="rel-person-a-list">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Step 3: Person B -->
        <div class="rel-step-content" id="rel-step-3" hidden>
          <p class="rel-step-desc">Select the second person</p>
          <div class="rel-person-list" id="rel-person-b-list">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Step 4: Details -->
        <div class="rel-step-content" id="rel-step-4" hidden>
          <div id="rel-details-form">
            <!-- Spouse details -->
            <div id="spouse-details" class="rel-detail-section" hidden>
              <div class="field">
                <label for="marriage-date" class="field-label">Marriage date <span class="field-optional">(optional)</span></label>
                <input type="date" id="marriage-date" class="field-input" />
              </div>
              <div id="is-primary-wrap" class="field" hidden>
                <label class="checkbox-label">
                  <input type="checkbox" id="is-primary-check" />
                  <span>Primary spouse</span>
                </label>
              </div>
              <div id="end-relationship-wrap" class="field">
                <label class="checkbox-label">
                  <input type="checkbox" id="end-relationship-check" />
                  <span>This relationship has ended</span>
                </label>
              </div>
              <div id="ended-details" class="rel-ended-details" hidden>
                <div class="field">
                  <label for="divorce-date" class="field-label">End date</label>
                  <input type="date" id="divorce-date" class="field-input" />
                </div>
                <div class="field">
                  <label for="ended-reason" class="field-label">Reason</label>
                  <select id="ended-reason" class="field-input field-select">
                    <option value="">Select reason</option>
                    <option value="divorce">Divorce</option>
                    <option value="death">Death</option>
                  </select>
                </div>
              </div>
            </div>
            <!-- Parent-child details -->
            <div id="parent-child-details" class="rel-detail-section" hidden>
              <div id="adopted-wrap" class="field">
                <label class="checkbox-label">
                  <input type="checkbox" id="is-adopted-check" />
                  <span>This child is adopted</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="rel-modal-footer">
          <button type="button" class="btn btn-ghost btn-sm" id="rel-back-btn" hidden>Back</button>
          <button type="button" class="btn btn-primary btn-sm" id="rel-next-btn" disabled>Next</button>
          <button type="button" class="btn btn-primary btn-sm" id="rel-create-btn" hidden>
            Add relationship
          </button>
        </div>

        <div id="rel-error" class="rel-error" hidden></div>
      </div>
    </div>
  </div>
  </div>
</Layout>

<style>
  .tree-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* --- Top Bar --- */
  .top-bar {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .top-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-4);
  }

  .top-bar-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .top-bar-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .nav-back {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    color: var(--color-on-surface-variant);
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                color var(--duration-fast) var(--ease-out-quint);
    flex-shrink: 0;
  }

  .nav-back:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .tree-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* --- Tree Canvas --- */
  .tree-canvas {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* --- Tree Toolbar --- */
  .tree-toolbar {
    position: absolute;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-1);
  }

  .toolbar-group {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .toolbar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    border: none;
    background: transparent;
    color: var(--color-on-surface-variant);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                color var(--duration-fast) var(--ease-out-quint);
    /* Ensure minimum 44x44px touch target on mobile */
    min-width: 44px;
    min-height: 44px;
  }

  .toolbar-btn:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .toolbar-btn:active {
    transform: scale(0.92);
  }

  .toolbar-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .toolbar-separator {
    width: 1px;
    height: 20px;
    background-color: var(--color-outline-variant);
    margin: 0 var(--space-1);
  }

  /* --- Breadcrumb --- */
  .tree-breadcrumb {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 50;
    max-width: 300px;
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    font-size: var(--text-xs);
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .breadcrumb-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-full);
    color: var(--color-on-surface-variant);
    text-decoration: none;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                color var(--duration-fast) var(--ease-out-quint);
    font-weight: 500;
  }

  .breadcrumb-link:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .breadcrumb-link.active {
    background-color: var(--color-primary-fixed);
    color: var(--color-on-primary-fixed);
  }

  .breadcrumb-sep {
    color: var(--color-outline);
    font-size: 10px;
  }

  .breadcrumb-avatar {
    width: 18px;
    height: 18px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-fixed-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 600;
    color: var(--color-on-primary-fixed);
    flex-shrink: 0;
  }

  /* --- Tree SVG --- */
  .tree-svg-wrapper {
    flex: 1;
    width: 100%;
    height: 100%;
    cursor: grab;
  }

  .tree-svg-wrapper:active {
    cursor: grabbing;
  }

  #tree-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* D3 node styles (in SVG) */
  :global(.tree-node-group) {
    cursor: pointer;
  }

  :global(.tree-node-avatar) {
    transition: transform var(--duration-fast) var(--ease-out-quint);
  }

  :global(.tree-node-group:hover .tree-node-avatar) {
    transform: scale(1.06);
  }

  :global(.tree-node-ring) {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 0;
    transition: stroke-width var(--duration-fast) var(--ease-out-quint);
  }

  :global(.tree-node-group.selected .tree-node-ring) {
    stroke-width: 3;
  }

  :global(.tree-node-root .tree-node-ring) {
    stroke: var(--color-secondary);
    stroke-width: 2.5;
    stroke-dasharray: 4 2;
  }

  :global(.tree-node-initials) {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 500;
    fill: var(--color-on-primary-fixed);
    pointer-events: none;
    user-select: none;
  }

  :global(.tree-node-name) {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    fill: var(--color-on-surface);
    pointer-events: none;
    user-select: none;
  }

  :global(.tree-node-dates) {
    font-family: var(--font-body);
    font-size: 9px;
    fill: var(--color-on-surface-variant);
    pointer-events: none;
    user-select: none;
  }

  :global(.tree-link) {
    fill: none;
    stroke: var(--color-secondary-fixed-dim);
    stroke-width: 2;
    stroke-linecap: round;
  }

  :global(.tree-link-spouse) {
    stroke: var(--color-secondary-fixed);
    stroke-dasharray: 5 3;
  }

  :global(.tree-collapse-btn) {
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-out-quint);
  }

  :global(.tree-collapse-btn:hover) {
    transform: scale(1.2);
  }

  :global(.tree-collapse-g) { cursor: pointer; }

  :global(.tree-collapsed-count) {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    fill: var(--color-on-surface-variant);
    pointer-events: none;
  }

  /* --- Loading --- */
  .tree-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
    z-index: 60;
  }

  .tree-loading-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-on-surface-variant);
    font-size: var(--text-sm);
  }

  /* --- Empty State --- */
  .empty-tree-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-5);
    padding: var(--space-16) 0;
    max-width: 440px;
    margin-inline: auto;
  }

  .empty-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
  }

  .empty-body {
    font-size: var(--text-base);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  .empty-note {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    font-style: italic;
  }

  /* --- Relationship Modal --- */
  .rel-modal {
    position: fixed;
    inset: 0;
    z-index: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .rel-modal-backdrop {
    position: absolute;
    inset: 0;
    background-color: oklch(0% 0 0 / 35%);

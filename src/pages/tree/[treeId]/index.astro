    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: none;
    background: transparent;
    color: var(--color-on-surface-variant);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quint);
  }

  .rel-modal-close:hover {
    background-color: var(--color-surface-container);
  }

  .rel-steps {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-surface-variant);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .rel-step::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: currentColor;
    margin-right: var(--space-2);
    opacity: 0.4;
  }

  .rel-step.active::before { opacity: 1; }
  .rel-step.active { color: var(--color-primary); }

  .rel-step-content {
    padding: var(--space-6);
    flex: 1;
  }

  .rel-step-desc {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-5);
  }

  .rel-type-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .rel-type-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-3);
    background-color: var(--color-surface-container-low);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-xl);
    cursor: pointer;
    text-align: center;
    transition: border-color var(--duration-fast) var(--ease-out-quint),
                background-color var(--duration-fast) var(--ease-out-quint);
    color: var(--color-on-surface-variant);
  }

  .rel-type-btn:hover {
    border-color: var(--color-primary);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .rel-type-btn.selected {
    border-color: var(--color-primary);
    background-color: oklch(35% 0.03 145 / 8%);
    color: var(--color-primary);
  }

  .rel-type-label {
    font-size: var(--text-sm);
    font-weight: 600;
    display: block;
  }

  .rel-type-desc {
    font-size: var(--text-xs);
    color: var(--color-on-surface-variant);
    display: block;
  }

  .rel-person-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-height: 280px;
    overflow-y: auto;
  }

  .rel-person-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background-color: var(--color-surface-container-low);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-xl);
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition: border-color var(--duration-fast) var(--ease-out-quint);
  }

  .rel-person-item:hover {
    border-color: var(--color-primary);
  }

  .rel-person-item.selected {
    border-color: var(--color-primary);
    background-color: oklch(35% 0.03 145 / 8%);
  }

  .rel-person-item.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .rel-person-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-fixed-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-on-primary-fixed);
    flex-shrink: 0;
  }

  .rel-person-info { flex: 1; min-width: 0; }
  .rel-person-name { font-size: var(--text-sm); font-weight: 600; }
  .rel-person-dates { font-size: var(--text-xs); color: var(--color-on-surface-variant); }

  .rel-detail-section { display: flex; flex-direction: column; gap: var(--space-4); }

  .field { display: flex; flex-direction: column; gap: var(--space-2); }

  .field-label { font-size: var(--text-sm); font-weight: 600; }
  .field-optional { font-weight: 400; color: var(--color-on-surface-variant); }

  .field-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-on-surface);
    background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint);
  }

  .field-input:focus { border-color: var(--color-primary); }
  .field-select { cursor: pointer; }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--color-outline);
    border-radius: var(--radius-sm);
    cursor: pointer;
    accent-color: var(--color-primary);
  }

  .rel-ended-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-outline-variant);
  }

  .rel-modal-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    border-top: 1px solid var(--color-outline-variant);
    flex-shrink: 0;
  }

  .rel-error {
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);

---
import Layout from '../../../layouts/Layout.astro';
const { treeId, memberId } = Astro.params;
---

<Layout title="Member profile">
  <div class="profile-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href={`/tree/${treeId}`} class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
            <path d="M12 4l-6 6 6 6"/>
          </svg>
          Back to tree
        </a>
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="profile-main container">
      <div id="profile-loading" class="profile-card">
        <div style="text-align:center;padding:40px;color:var(--color-on-surface-variant)">Loading member...</div>
      </div>
      <div id="profile-error" class="profile-card" hidden>
        <div style="text-align:center;padding:40px;">
          <p style="color:var(--color-error);margin-bottom:16px">Failed to load member</p>
          <a href={`/tree/${treeId}`} class="btn btn-ghost">Back to tree</a>
        </div>
      </div>
      <div id="profile-content" class="profile-card" hidden>
        <!-- Header -->
        <div class="profile-header">
          <div class="profile-avatar" id="profile-avatar"></div>
          <div class="profile-header-text">
            <h1 class="profile-name" id="profile-name"></h1>
            <span class="profile-root-badge" id="profile-root-badge" hidden>Root ancestor</span>
            <p class="profile-vitals" id="profile-vitals"></p>
          </div>
        </div>

        <!-- Bio -->
        <div class="profile-section" id="profile-bio-section" hidden>
          <h2 class="profile-section-title">About</h2>
          <div class="profile-bio" id="profile-bio"></div>
        </div>

        <!-- Details grid -->
        <div class="profile-section" id="profile-details-section" hidden>
          <h2 class="profile-section-title">Details</h2>
          <dl class="profile-details-grid" id="profile-details"></dl>
        </div>

        <!-- Family links -->
        <div class="profile-section" id="profile-family-section" hidden>
          <h2 class="profile-section-title">Family</h2>
          <div class="family-links" id="family-links"></div>
        </div>

        <!-- Actions -->
        <div class="profile-actions" id="profile-actions"></div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .profile-shell { min-height: 100dvh; display: flex; flex-direction: column; }
  .top-nav { background-color: var(--color-surface-container-lowest); border-bottom: 1px solid var(--color-outline-variant); position: sticky; top: 0; z-index: 100; }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .back-link { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); font-weight: 500; color: var(--color-on-surface-variant); text-decoration: none; }
  .back-link:hover { color: var(--color-on-surface); }
  .wordmark { display: flex; align-items: center; gap: var(--space-2); text-decoration: none; color: var(--color-on-surface); font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500; }
  .profile-main { flex: 1; padding-block: var(--space-8) var(--space-16); }
  .profile-card { background-color: var(--color-surface-container-lowest); border-radius: var(--radius-2xl); border: 1px solid var(--color-outline-variant); padding: var(--space-8); max-width: 680px; margin-inline: auto; width: 100%; }
  .profile-header { display: flex; align-items: flex-start; gap: var(--space-6); margin-bottom: var(--space-8); padding-bottom: var(--space-8); border-bottom: 1px solid var(--color-outline-variant); }
  .profile-avatar { width: 80px; height: 80px; border-radius: var(--radius-full); background-color: var(--color-primary-fixed-dim); display: flex; align-items: center; justify-content: center; font-size: var(--text-2xl); font-weight: 600; color: var(--color-on-primary-fixed); overflow: hidden; flex-shrink: 0; }
  .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .profile-header-text { flex: 1; }
  .profile-name { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 500; margin-bottom: var(--space-1); }
  .profile-root-badge { display: inline-block; font-size: var(--text-xs); font-weight: 600; color: var(--color-primary); background-color: oklch(35% 0.03 145 / 12%); padding: 2px 8px; border-radius: var(--radius-full); margin-bottom: var(--space-2); }
  .profile-vitals { font-size: var(--text-sm); color: var(--color-on-surface-variant); margin-bottom: 0; }
  .profile-section { margin-bottom: var(--space-8); }
  .profile-section:last-child { margin-bottom: 0; }
  .profile-section-title { font-size: var(--text-sm); font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-on-surface-variant); margin-bottom: var(--space-4); }
  .profile-bio { font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--color-on-surface); white-space: pre-wrap; }
  .profile-details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .detail-label { font-size: var(--text-sm); color: var(--color-on-surface-variant); margin-bottom: 2px; }
  .detail-value { font-size: var(--text-base); font-weight: 500; color: var(--color-on-surface); margin-bottom: var(--space-4); }
  .family-links { display: flex; flex-direction: column; gap: var(--space-3); }
  .family-link-row { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3); border-radius: var(--radius-lg); background-color: var(--color-surface-container-low); text-decoration: none; color: inherit; transition: background-color var(--duration-fast) var(--ease-out-quint); }
  .family-link-row:hover { background-color: var(--color-surface-container); }
  .family-link-avatar { width: 36px; height: 36px; border-radius: var(--radius-full); background-color: var(--color-primary-fixed-dim); display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: 600; color: var(--color-on-primary-fixed); overflow: hidden; flex-shrink: 0; }
  .family-link-info { flex: 1; }
  .family-link-name { font-size: var(--text-sm); font-weight: 600; color: var(--color-on-surface); }
  .family-link-role { font-size: var(--text-xs); color: var(--color-on-surface-variant); }
  .profile-actions { display: flex; gap: var(--space-3); margin-top: var(--space-6); padding-top: var(--space-6); border-top: 1px solid var(--color-outline-variant); }
  .btn { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-6); font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; border-radius: var(--radius-full); border: none; cursor: pointer; text-decoration: none; transition: all var(--duration-fast) var(--ease-out-quint); }
  .btn-primary { background-color: var(--color-primary); color: var(--color-on-primary); }
  .btn-ghost { background-color: transparent; color: var(--color-on-surface-variant); }
  .btn-ghost:hover { background-color: var(--color-surface-container); color: var(--color-on-surface); }
  @media (max-width: 480px) { .profile-header { flex-direction: column; } .profile-details-grid { grid-template-columns: 1fr; } }
</style>

<script define:vars={{ treeId, memberId }}>
  import { getCurrentUser } from '../../../lib/store';

  if (!getCurrentUser()) {
    window.location.href = '/auth/magic-link';
  }

  async function loadMember() {
    const loadingEl = document.getElementById('profile-loading');
    const errorEl = document.getElementById('profile-error');
    const contentEl = document.getElementById('profile-content');

    try {
      const [memberRes, graphRes] = await Promise.all([
        fetch(`/api/trees/${treeId}/members/${memberId}`),
        fetch(`/api/trees/${treeId}/graph`),
      ]);

      if (!memberRes.ok) throw new Error();

      const member = await memberRes.json();
      const graph = graphRes.ok ? await graphRes.json() : { members: [], relationships: [] };

      if (loadingEl) loadingEl.hidden = true;
      if (contentEl) contentEl.hidden = false;

      // Avatar
      const avatarEl = document.getElementById('profile-avatar');
      if (avatarEl) {
        if (member.profile_photo_url) {
          avatarEl.innerHTML = `<img src="${member.profile_photo_url}" alt="" />`;
        } else {
          avatarEl.textContent = `${member.first_name[0]}${member.last_name[0]}`;
        }
      }

      // Name
      const nameEl = document.getElementById('profile-name');
      if (nameEl) nameEl.textContent = `${member.first_name} ${member.last_name}`;

      // Root badge
      const rootBadge = document.getElementById('profile-root-badge');
      if (rootBadge) rootBadge.hidden = !member.is_root;

      // Vitals
      const vitalsEl = document.getElementById('profile-vitals');
      if (vitalsEl) {
        const parts = [];
        if (member.birth_date) parts.push(`Born ${new Date(member.birth_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`);
        if (member.birth_place) parts.push(`in ${member.birth_place}`);
        if (member.death_date) parts.push(`— Died ${new Date(member.death_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`);
        vitalsEl.textContent = parts.join(' ');
      }

      // Bio
      const bioSection = document.getElementById('profile-bio-section');
      const bioEl = document.getElementById('profile-bio');
      if (bioSection && bioEl && member.bio) {
        bioSection.hidden = false;
        bioEl.textContent = member.bio;
      }

      // Details
      const detailsSection = document.getElementById('profile-details-section');
      const detailsEl = document.getElementById('profile-details');
      if (detailsSection && detailsEl) {
        const details = [];
        if (member.gender) details.push({ label: 'Gender', value: member.gender.charAt(0).toUpperCase() + member.gender.slice(1) });
        if (member.occupation) details.push({ label: 'Occupation', value: member.occupation });
        if (member.location) details.push({ label: 'Location', value: member.location });
        if (member.email) details.push({ label: 'Email', value: member.email });
        if (member.phone) details.push({ label: 'Phone', value: member.phone });

        if (details.length > 0) {
          detailsSection.hidden = false;
          detailsEl.innerHTML = details.map(d => `<dt class="detail-label">${d.label}</dt><dd class="detail-value">${d.value}</dd>`).join('');
        }
      }

      // Family relationships
      const familySection = document.getElementById('profile-family-section');
      const familyLinksEl = document.getElementById('family-links');
      if (familySection && familyLinksEl) {
        const rels = graph.relationships.filter((r) => r.person_a_id === memberId || r.person_b_id === memberId);
        const family = [];

        rels.forEach(rel => {
          const otherId = rel.person_a_id === memberId ? rel.person_b_id : rel.person_a_id;
          const other = graph.members.find(m => m.id === otherId);
          if (!other) return;

          let role = rel.relationship_type;
          if (rel.person_a_id === memberId) {
            if (rel.relationship_type === 'parent_child') role = 'Child';
            else if (rel.relationship_type === 'spouse') role = 'Spouse';
            else if (rel.relationship_type === 'step_sibling') role = 'Step sibling';
          } else {
            if (rel.relationship_type === 'parent_child') role = 'Parent';
            else if (rel.relationship_type === 'spouse') role = 'Spouse';
            else if (rel.relationship_type === 'step_sibling') role = 'Step sibling';
          }
          family.push({ member: other, role });
        });

        if (family.length > 0) {
          familySection.hidden = false;
          familyLinksEl.innerHTML = family.map(f => `
            <a href="/tree/${treeId}/person/${f.member.id}" class="family-link-row">
              <div class="family-link-avatar">${f.member.first_name[0]}${f.member.last_name[0]}</div>
              <div class="family-link-info">
                <div class="family-link-name">${f.member.first_name} ${f.member.last_name}</div>
                <div class="family-link-role">${f.role}</div>
              </div>
            </a>
          `).join('');
        }
      }

      // Actions - Edit button
      const actionsEl = document.getElementById('profile-actions');
      if (actionsEl) {
        actionsEl.innerHTML = `
          <a href="/tree/${treeId}/members/${memberId}/edit" class="btn btn-primary">Edit member</a>
          <a href="/tree/${treeId}" class="btn btn-ghost">Back to tree</a>
        `;
      }

    } catch {
      if (loadingEl) loadingEl.hidden = true;
      if (errorEl) errorEl.hidden = false;
    }
  }

  loadMember();
</script>
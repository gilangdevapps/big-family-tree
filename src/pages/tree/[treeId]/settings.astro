---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Tree settings">
  <div class="page-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href={`/tree/${treeId}`} class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
            <path d="M12 4l-6 6 6 6"/>
          </svg>
          Back
        </a>
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="page-main container">
      <div class="settings-container">
        <div class="settings-header">
          <h1 class="settings-title">Tree settings</h1>
        </div>

        <!-- Rename -->
        <section class="settings-section">
          <h2 class="settings-section-title">Rename tree</h2>
          <div class="rename-form">
            <div class="field">
              <label for="tree-name" class="field-label">Tree name</label>
              <input
                type="text"
                id="tree-name"
                class="field-input"
                value=""
                placeholder="Tree name"
                maxlength="100"
              />
            </div>
            <button type="button" class="btn btn-primary btn-sm" id="save-name-btn">
              Save name
            </button>
          </div>
          <span id="rename-success" class="inline-success" hidden>Name saved</span>
        </section>

        <!-- Root person -->
        <section class="settings-section">
          <h2 class="settings-section-title">Root ancestor</h2>
          <p class="settings-section-desc">The person at the top of your family tree — the oldest person you know.</p>
          <div class="field">
            <label for="root-person" class="field-label">Root person</label>
            <select id="root-person" class="field-input field-select" data-selected="">
              <option value="">Not set</option>
            </select>
          </div>
          <button type="button" class="btn btn-primary btn-sm" id="save-root-btn">
            Save root person
          </button>
          <span id="root-success" class="inline-success" hidden>Root person saved</span>
        </section>

        <!-- Members & Access -->
        {isOwnerOrAdmin && (
          <section class="settings-section">
            <div class="section-header">
              <h2 class="settings-section-title">Members & Access</h2>
              <button type="button" class="btn btn-outline btn-sm" id="open-invite-panel-btn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <path d="M8 2v12M2 8h12"/>
                </svg>
                Invite member
              </button>
            </div>
            <div id="membership-list" class="membership-list">
              <div class="membership-loading">Loading members...</div>
            </div>
          </section>

        <!-- Invite Panel (slide-in) -->
        <div id="invite-panel" class="invite-panel" hidden>
          <div class="invite-panel-backdrop" id="invite-panel-backdrop"></div>
          <div class="invite-panel-sheet">
            <div class="invite-panel-header">
              <h2 class="invite-panel-title">Invite a family member</h2>
              <button class="panel-close-btn" id="close-invite-panel-btn" aria-label="Close invite panel">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M5 5l10 10M15 5L5 15"/>
                </svg>
              </button>
            </div>
            <div class="invite-panel-body">
              <div id="invite-form-section">
                <div class="field">
                  <label for="invite-email" class="field-label">Email address</label>
                  <input type="email" id="invite-email" class="field-input" placeholder="someone@example.com" autocomplete="off" />
                  <span id="invite-email-error" class="field-error" hidden></span>
                </div>
                <div class="field">
                  <label for="invite-role" class="field-label">Role</label>
                  <select id="invite-role" class="field-input field-select">
                    <option value="family_member">Family Member — can view and edit profiles</option>
                    <option value="admin">Admin — full access including member management</option>
                  </select>
                </div>
                <button type="button" class="btn btn-primary" id="create-invite-btn">
                  Create invite
                </button>
              </div>
              <div id="invite-result-section" class="invite-result" hidden>
                <div class="invite-result-header">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <circle cx="10" cy="10" r="8"/>
                    <path d="M7 10l2 2 4-4"/>
                  </svg>
                  <p class="invite-result-title">Invite link ready</p>
                </div>
                <p class="invite-result-desc">Share this link with them. It never expires.</p>
                <div class="invite-link-row">
                  <input type="text" id="invite-link-input" class="field-input invite-link-input" readonly />
                  <button type="button" class="btn btn-outline btn-sm" id="copy-invite-btn">Copy</button>
                </div>
              </div>
              <div id="pending-invites-section">
                <h3 class="pending-invites-title">Pending invites</h3>
                <div id="pending-invites-list" class="pending-invites-list">
                  <div class="membership-loading">Loading invites...</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Danger zone -->
        {tree.owner_id === user.id && (
          <section class="settings-section danger-zone">
            <h2 class="danger-title">Danger zone</h2>
            <div class="danger-content">
              <div class="danger-text">
                <p class="danger-heading">Delete this tree</p>
                <p class="danger-desc">
                  This will permanently delete the tree and all its members. This action cannot be undone.
                </p>
              </div>
              <button type="button" class="btn btn-danger" id="delete-tree-btn">
                Delete tree
              </button>
            </div>
          </section>
        )}

        <!-- Delete confirmation modal -->
        <div id="delete-modal" class="modal" hidden role="dialog" aria-modal="true" aria-labelledby="modal-title">
          <div class="modal-backdrop" id="modal-backdrop"></div>
          <div class="modal-card">
            <h2 class="modal-title" id="modal-title">Delete this tree?</h2>
            <p class="modal-body">
              This will permanently remove the tree and all its members.
              Type the tree name below to confirm.
            </p>
            <div class="field">
              <label for="delete-confirm-input" class="field-label">
                Type the tree name to confirm
              </label>
              <input type="text" id="delete-confirm-input" class="field-input" autocomplete="off" />
            </div>
            <div id="modal-error" class="modal-error" hidden></div>
            <div class="modal-actions">
              <button type="button" class="btn btn-ghost" id="cancel-delete-btn">Cancel</button>
              <button type="button" class="btn btn-danger" id="confirm-delete-btn" disabled>
                Delete forever
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .page-shell { min-height: 100dvh; display: flex; flex-direction: column; }

  .top-nav {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky; top: 0; z-index: 100;
  }

  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px; gap: var(--space-4);
  }

  .back-link {
    display: flex; align-items: center; gap: var(--space-2);
    font-size: var(--text-sm); font-weight: 500;
    color: var(--color-on-surface-variant); text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quint);
  }
  .back-link:hover { color: var(--color-on-surface); }

  .wordmark {
    display: flex; align-items: center; gap: var(--space-2);
    text-decoration: none; color: var(--color-on-surface);
    font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500;
  }

  .page-main {
    flex: 1; display: flex; align-items: flex-start; justify-content: center;
    padding-block: var(--space-12) var(--space-16);
  }

  .settings-container { width: 100%; max-width: 520px; }

  .settings-header { margin-bottom: var(--space-10); }

  .settings-title {
    font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 500;
  }

  .settings-section {
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .settings-section-title {
    font-size: var(--text-base); font-weight: 600; margin-bottom: var(--space-3);
  }

  .settings-section-desc {
    font-size: var(--text-sm); color: var(--color-on-surface-variant);
    margin-bottom: var(--space-4);
  }

  .rename-form {
    display: flex; align-items: flex-end; gap: var(--space-4); margin-bottom: var(--space-3);
  }

  .rename-form .field { flex: 1; margin-bottom: 0; }

  .field { display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-4); }

  .field-label { font-size: var(--text-sm); font-weight: 600; }

  .field-input {
    width: 100%; padding: var(--space-3) var(--space-4);
    font-family: var(--font-body); font-size: var(--text-base);
    color: var(--color-on-surface); background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant); border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint);
  }
  .field-input:focus { border-color: var(--color-primary); }
  .field-select { cursor: pointer; }

  .inline-success {
    font-size: var(--text-sm); color: var(--color-primary); font-weight: 500;
  }

  /* --- Danger Zone --- */
  .danger-zone { border-bottom: none; }

  .danger-title {
    font-size: var(--text-base); font-weight: 600;
    color: var(--color-error); margin-bottom: var(--space-4);
  }

  .danger-content {
    display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-4);
    padding: var(--space-5);
    background-color: var(--color-error-container);
    border-radius: var(--radius-xl);
  }

  .danger-text { flex: 1; }

  .danger-heading {
    font-weight: 600; font-size: var(--text-base);
    color: var(--color-on-error-container); margin-bottom: var(--space-1);
  }

  .danger-desc {
    font-size: var(--text-sm); color: var(--color-on-error-container); opacity: 0.8;
  }

  /* --- Modal --- */
  .modal {
    position: fixed; inset: 0; z-index: 300;
    display: flex; align-items: center; justify-content: center;
    padding: var(--space-4);
  }

  .modal-backdrop {
    position: absolute; inset: 0;
    background-color: oklch(0% 0 0 / 40%);
    cursor: pointer;
  }

  .modal-card {
    position: relative; z-index: 1;
    width: 100%; max-width: 440px;
    background-color: var(--color-surface-container-lowest);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-outline-variant);
    box-shadow: var(--shadow-2);
    padding: var(--space-8);
  }

  .modal-title {
    font-family: var(--font-display); font-size: var(--text-xl); font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .modal-body {
    font-size: var(--text-sm); color: var(--color-on-surface-variant);
    margin-bottom: var(--space-6); line-height: var(--leading-relaxed);
  }

  .modal-error {
    padding: var(--space-3); margin-bottom: var(--space-4);
    background-color: var(--color-error-container); color: var(--color-on-error-container);
    border-radius: var(--radius-md); font-size: var(--text-sm);
  }

  .modal-actions {
    display: flex; justify-content: flex-end; gap: var(--space-3);
  }

  /* --- Buttons --- */
  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
    border-radius: var(--radius-full); border: none; cursor: pointer; text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out-quint);
  }
  .btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
  .btn-primary { background-color: var(--color-primary); color: var(--color-on-primary); }
  .btn-primary:hover:not(:disabled) { background-color: var(--color-primary-container); }
  .btn-ghost { background-color: transparent; color: var(--color-on-surface-variant); }
  .btn-ghost:hover { background-color: var(--color-surface-container); color: var(--color-on-surface); }
  .btn-danger {
    background-color: var(--color-error); color: var(--color-on-error);
  }
  .btn-danger:hover:not(:disabled) { background-color: oklch(40% 0.2 25); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-sm { padding: var(--space-2) var(--space-4); }
  .btn-outline { background-color: transparent; color: var(--color-primary); border: 1.5px solid var(--color-primary); }
  .btn-outline:hover { background-color: oklch(35% 0.03 145 / 8%); }

  /* --- Membership List --- */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .membership-list {
    display: flex; flex-direction: column; gap: var(--space-3);
  }

  .membership-row {
    display: flex; align-items: center; gap: var(--space-4);
    padding: var(--space-4);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--color-outline-variant);
  }

  .membership-avatar {
    width: 40px; height: 40px; border-radius: var(--radius-full);
    background-color: var(--color-primary-fixed-dim);
    display: flex; align-items: center; justify-content: center;
    font-size: var(--text-sm); font-weight: 600;
    color: var(--color-on-primary-fixed); flex-shrink: 0;
  }

  .membership-info { flex: 1; min-width: 0; }
  .membership-email {
    font-size: var(--text-sm); font-weight: 600;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .membership-meta { font-size: var(--text-xs); color: var(--color-on-surface-variant); }

  .membership-controls {
    display: flex; align-items: center; gap: var(--space-3); flex-shrink: 0;
  }

  .membership-role-select {
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-body); font-size: var(--text-sm);
    color: var(--color-on-surface);
    background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-md); cursor: pointer; outline: none;
  }
  .membership-role-select:focus { border-color: var(--color-primary); }

  .membership-remove-btn {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: var(--radius-full);
    border: none; background-color: transparent; cursor: pointer;
    color: var(--color-on-surface-variant);
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                color var(--duration-fast) var(--ease-out-quint);
  }
  .membership-remove-btn:hover { background-color: var(--color-error-container); color: var(--color-error); }

  .self-badge {
    font-size: var(--text-xs); font-weight: 600;
    padding: 2px 8px; border-radius: var(--radius-full);
    background-color: var(--color-primary-fixed);
    color: var(--color-on-primary-fixed);
  }

  .pending-badge {
    font-size: var(--text-xs); font-weight: 600;
    padding: 2px 8px; border-radius: var(--radius-full);
    background-color: var(--color-secondary-fixed);
    color: var(--color-on-secondary-fixed);
  }

  .membership-loading {
    font-size: var(--text-sm); color: var(--color-on-surface-variant);
    padding: var(--space-4);
  }

  /* --- Invite Panel --- */
  .invite-panel {
    position: fixed; inset: 0; z-index: 300;
    display: flex; align-items: flex-start; justify-content: flex-end;
  }

  .invite-panel-backdrop {
    position: absolute; inset: 0;
    background-color: oklch(0% 0 0 / 30%);
    cursor: pointer;
  }

  .invite-panel-sheet {
    position: relative; z-index: 1;
    width: 420px; max-width: 100vw; height: 100dvh;
    background-color: var(--color-surface-container-lowest);
    border-left: 1px solid var(--color-outline-variant);
    box-shadow: var(--shadow-2);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-slow) var(--ease-out-quint);
    overflow: hidden;
  }

  .invite-panel:not([hidden]) .invite-panel-sheet {
    transform: translateX(0);
  }

  .invite-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-6);
    border-bottom: 1px solid var(--color-outline-variant);
    flex-shrink: 0;
  }

  .invite-panel-title {
    font-family: var(--font-display); font-size: var(--text-xl); font-weight: 500;
  }

  .panel-close-btn {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: var(--radius-full);
    border: none; background-color: transparent;
    color: var(--color-on-surface-variant); cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                color var(--duration-fast) var(--ease-out-quint);
  }
  .panel-close-btn:hover { background-color: var(--color-surface-container); color: var(--color-on-surface); }

  .invite-panel-body {
    flex: 1; overflow-y: auto; padding: var(--space-6);
    display: flex; flex-direction: column; gap: var(--space-6);
  }

  .field-error {
    font-size: var(--text-xs); color: var(--color-error); font-weight: 500;
  }

  .invite-result {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-xl); padding: var(--space-5);
  }

  .invite-result-header {
    display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-2);
  }

  .invite-result-title { font-size: var(--text-base); font-weight: 600; }

  .invite-result-desc {
    font-size: var(--text-sm); color: var(--color-on-surface-variant);
    margin-bottom: var(--space-4);
  }

  .invite-link-row { display: flex; gap: var(--space-2); }
  .invite-link-input { flex: 1; font-size: var(--text-sm); }

  .pending-invites-title {
    font-size: var(--text-xs); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--color-on-surface-variant);
    margin-bottom: var(--space-3);
  }

  .pending-invites-list {
    display: flex; flex-direction: column; gap: var(--space-3);
  }

  .pending-invite-row {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-lg);
  }

  .pending-invite-email { flex: 1; font-size: var(--text-sm); font-weight: 500; }
  .pending-invite-meta { font-size: var(--text-xs); color: var(--color-on-surface-variant); }
  .pending-invite-revoke {
    font-size: var(--text-xs); color: var(--color-error); font-weight: 600;
    border: none; background: none; cursor: pointer; padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: background-color var(--duration-fast);
  }
  .pending-invite-revoke:hover { background-color: var(--color-error-container); }

  .no-pending { font-size: var(--text-sm); color: var(--color-on-surface-variant); font-style: italic; }
</style>

<script define:vars={{ treeId }}>
  import { getCurrentUser, userIsAdmin } from '../../../lib/store';

  // Auth check
  if (!getCurrentUser()) {
    window.location.href = '/auth/magic-link';
  }

  const currentUser = getCurrentUser();
  const isAdmin = currentUser ? userIsAdmin(treeId, currentUser.id) : false;
  const currentUserId = currentUser?.id ?? '';

  // Extract treeId from URL path as fallback
  const pathParts = window.location.pathname.split('/');
  const urlTreeId = pathParts[2] || treeId;

  // Fetch tree data client-side
  let treeName = '';

  async function fetchTreeData() {
    try {
      const res = await fetch(`/api/trees/${urlTreeId}`);
      if (res.ok) {
        const tree = await res.json();
        treeName = tree.name;
        document.title = `${tree.name} — Settings — Big Family Tree`;
        const nameInput = document.getElementById('tree-name') as HTMLInputElement;
        if (nameInput) nameInput.value = tree.name;
        const nameHeading = document.getElementById('tree-name-heading');
        if (nameHeading) nameHeading.textContent = tree.name;
      }
    } catch {}
  }
  await fetchTreeData();

  // Rename
  const nameInput = document.getElementById('tree-name') as HTMLInputElement;
  const saveNameBtn = document.getElementById('save-name-btn') as HTMLButtonElement;
  const renameSuccess = document.getElementById('rename-success') as HTMLSpanElement;

  saveNameBtn.addEventListener('click', async () => {
    const name = nameInput.value.trim();
    if (!name || name === treeName) return;

    saveNameBtn.disabled = true;
    try {
      const res = await fetch(`/api/trees/${treeId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ name }),
      });
      if (!res.ok) throw new Error();
      renameSuccess.hidden = false;
      setTimeout(() => { renameSuccess.hidden = true; }, 2000);
    } catch {
      nameInput.value = treeName;
    } finally {
      saveNameBtn.disabled = false;
    }
  });

  // Root person
  const rootSelect = document.getElementById('root-person') as HTMLSelectElement;
  const saveRootBtn = document.getElementById('save-root-btn') as HTMLButtonElement;
  const rootSuccess = document.getElementById('root-success') as HTMLSpanElement;

  saveRootBtn.addEventListener('click', async () => {
    saveRootBtn.disabled = true;
    try {
      const res = await fetch(`/api/trees/${treeId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ root_person_id: rootSelect.value || null }),
      });
      if (!res.ok) throw new Error();
      rootSuccess.hidden = false;
      setTimeout(() => { rootSuccess.hidden = true; }, 2000);
    } finally {
      saveRootBtn.disabled = false;
    }
  });

  // Delete modal
  const deleteModal = document.getElementById('delete-modal')!;
  const deleteTreeBtn = document.getElementById('delete-tree-btn') as HTMLButtonElement;
  const modalBackdrop = document.getElementById('modal-backdrop')!;
  const cancelDeleteBtn = document.getElementById('cancel-delete-btn') as HTMLButtonElement;
  const confirmDeleteBtn = document.getElementById('confirm-delete-btn') as HTMLButtonElement;
  const confirmInput = document.getElementById('delete-confirm-input') as HTMLInputElement;
  const modalError = document.getElementById('modal-error') as HTMLDivElement;

  function openModal() {
    deleteModal.hidden = false;
    confirmInput.value = '';
    confirmInput.focus();
    confirmDeleteBtn.disabled = true;
    modalError.hidden = true;
  }

  function closeModal() {
    deleteModal.hidden = true;
  }

  deleteTreeBtn.addEventListener('click', openModal);
  modalBackdrop.addEventListener('click', closeModal);
  cancelDeleteBtn.addEventListener('click', closeModal);

  confirmInput.addEventListener('input', () => {
    confirmDeleteBtn.disabled = confirmInput.value.trim() !== treeName;
  });

  confirmDeleteBtn.addEventListener('click', async () => {
    confirmDeleteBtn.disabled = true;
    try {
      const res = await fetch(`/api/trees/${treeId}`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (!res.ok) {
        const data = await res.json();
        throw new Error(data.error || 'Failed to delete');
      }
      window.location.href = '/dashboard';
    } catch (err) {
      modalError.textContent = err instanceof Error ? err.message : 'Failed to delete';
      modalError.hidden = false;
      confirmDeleteBtn.disabled = false;
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !deleteModal.hidden) closeModal();
  });

  // --- Membership & Invite Management ---

  // Toast helper
  function showToast(message: string, duration = 3500) {
    const existing = document.getElementById('app-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.id = 'app-toast';
    toast.className = 'app-toast';
    toast.textContent = message;
    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);padding:12px 20px;background:var(--color-inverse-surface);color:var(--color-inverse-on-surface);border-radius:9999px;font-size:14px;font-weight:500;z-index:9999;box-shadow:var(--shadow-2);transition:opacity 0.3s;opacity:1;';
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, duration);
  }

  // Membership list
  async function loadMemberships() {
    const listEl = document.getElementById('membership-list')!;
    try {
      const res = await fetch(`/api/trees/${treeId}/memberships`, { credentials: 'include' });
      if (!res.ok) throw new Error();
      const members = await res.json() as Array<{id: string; user_id: string; role: string; invited_at: string; joined_at: string; user_email: string}>;

      if (members.length === 0) {
        listEl.innerHTML = '<p class="membership-loading">No other members yet</p>';
        return;
      }

      listEl.innerHTML = members.map(m => {
        const isSelf = m.user_id === currentUserId;
        const initials = m.user_email ? m.user_email[0].toUpperCase() : '?';
        const joinDate = m.joined_at ? new Date(m.joined_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Pending';
        return `
          <div class="membership-row" data-membership-id="${m.id}" data-user-id="${m.user_id}">
            <div class="membership-avatar">${initials}</div>
            <div class="membership-info">
              <div class="membership-email">${m.user_email ?? 'Unknown email'}</div>
              <div class="membership-meta">
                ${isSelf ? '<span class="self-badge">You</span>' : ''}
                ${!isSelf && m.role === 'admin' ? '<span class="self-badge">Admin</span>' : ''}
                Joined ${joinDate}
              </div>
            </div>
            ${isSelf ? '<span class="self-badge">You (Admin)</span>' : `
              <div class="membership-controls">
                <select class="membership-role-select" data-membership-id="${m.id}" ${!isAdmin ? 'disabled' : ''}>
                  <option value="admin" ${m.role === 'admin' ? 'selected' : ''}>Admin</option>
                  <option value="family_member" ${m.role === 'family_member' ? 'selected' : ''}>Family Member</option>
                </select>
                <button class="membership-remove-btn" data-membership-id="${m.id}" data-email="${m.user_email}" title="Remove access" ${!isAdmin ? 'disabled' : ''}>
                  <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M5 5l10 10M15 5L5 15"/>
                  </svg>
                </button>
              </div>
            `}
          </div>
        `;
      }).join('');

      // Role change handlers
      listEl.querySelectorAll('.membership-role-select').forEach(select => {
        select.addEventListener('change', async (e) => {
          const target = e.target as HTMLSelectElement;
          const membershipId = target.dataset.membershipId;
          const newRole = target.value;
          target.disabled = true;
          try {
            const res = await fetch(`/api/trees/${treeId}/memberships/${membershipId}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ role: newRole }),
            });
            const data = await res.json();
            if (!res.ok) {
              if (data.code === 'SELF_DEMOTE_NOT_ALLOWED') {
                showToast('You cannot demote yourself. Transfer ownership first.');
              } else {
                showToast(data.error || 'Failed to update role');
              }
              loadMemberships(); // reload to reset
            } else {
              showToast('Role updated');
              loadMemberships();
            }
          } catch {
            showToast('Failed to update role');
            loadMemberships();
          }
        });
      });

      // Remove member handlers
      listEl.querySelectorAll('.membership-remove-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const membershipId = target.dataset.membershipId;
          const email = target.dataset.email;
          if (!confirm(`Remove ${email} from this tree?`)) return;
          target.disabled = true;
          try {
            const res = await fetch(`/api/trees/${treeId}/memberships/${membershipId}`, {
              method: 'DELETE',
              credentials: 'include',
            });
            if (!res.ok) {
              const data = await res.json();
              showToast(data.error || 'Failed to remove member');
              target.disabled = false;
            } else {
              showToast('Access revoked');
              loadMemberships();
              loadPendingInvites();
            }
          } catch {
            showToast('Failed to remove member');
            target.disabled = false;
          }
        });
      });

    } catch {
      listEl.innerHTML = '<p class="membership-loading">Failed to load members</p>';
    }
  }

  // Pending invites
  async function loadPendingInvites() {
    const listEl = document.getElementById('pending-invites-list')!;
    try {
      const res = await fetch(`/api/trees/${treeId}/invites`, { credentials: 'include' });
      if (!res.ok) throw new Error();
      const invites = await res.json() as Array<{id: string; email: string; role: string; created_at: string}>;

      if (invites.length === 0) {
        listEl.innerHTML = '<p class="no-pending">No pending invites</p>';
        return;
      }

      listEl.innerHTML = invites.map(inv => {
        const date = new Date(inv.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        return `
          <div class="pending-invite-row">
            <div style="flex:1">
              <div class="pending-invite-email">${inv.email}</div>
              <div class="pending-invite-meta">${inv.role === 'admin' ? 'Admin' : 'Family Member'} · Sent ${date}</div>
            </div>
            <button class="pending-invite-revoke" data-invite-id="${inv.id}">Revoke</button>
          </div>
        `;
      }).join('');

      listEl.querySelectorAll('.pending-invite-revoke').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const inviteId = target.dataset.inviteId;
          target.disabled = true;
          try {
            const res = await fetch(`/api/trees/${treeId}/invites/${inviteId}`, {
              method: 'DELETE',
              credentials: 'include',
            });
            if (!res.ok) throw new Error();
            showToast('Invite revoked');
            loadPendingInvites();
          } catch {
            showToast('Failed to revoke invite');
            target.disabled = false;
          }
        });
      });
    } catch {
      listEl.innerHTML = '<p class="membership-loading">Failed to load invites</p>';
    }
  }

  // Invite panel
  const invitePanel = document.getElementById('invite-panel')!;
  const openInviteBtn = document.getElementById('open-invite-panel-btn') as HTMLButtonElement;
  const closeInviteBtn = document.getElementById('close-invite-panel-btn')!;
  const inviteBackdrop = document.getElementById('invite-panel-backdrop')!;
  const inviteFormSection = document.getElementById('invite-form-section')!;
  const inviteResultSection = document.getElementById('invite-result-section')!;
  const createInviteBtn = document.getElementById('create-invite-btn') as HTMLButtonElement;
  const copyInviteBtn = document.getElementById('copy-invite-btn') as HTMLButtonElement;
  const inviteLinkInput = document.getElementById('invite-link-input') as HTMLInputElement;

  function openInvitePanel() {
    invitePanel.hidden = false;
    inviteFormSection.hidden = false;
    inviteResultSection.hidden = true;
    loadMemberships();
    loadPendingInvites();
  }

  function closeInvitePanel() {
    invitePanel.hidden = true;
  }

  openInviteBtn.addEventListener('click', openInvitePanel);
  closeInviteBtn.addEventListener('click', closeInvitePanel);
  inviteBackdrop.addEventListener('click', closeInvitePanel);

  createInviteBtn.addEventListener('click', async () => {
    const emailInput = document.getElementById('invite-email') as HTMLInputElement;
    const emailError = document.getElementById('invite-email-error')!;
    const roleSelect = document.getElementById('invite-role') as HTMLSelectElement;
    const email = emailInput.value.trim();
    const role = roleSelect.value;

    emailError.hidden = true;
    if (!email || !email.includes('@')) {
      emailError.textContent = 'Please enter a valid email address';
      emailError.hidden = false;
      return;
    }

    createInviteBtn.disabled = true;
    try {
      const res = await fetch(`/api/trees/${treeId}/invites`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, role }),
      });
      const data = await res.json();
      if (!res.ok) {
        if (data.error === 'This person is already a member of this tree') {
          emailError.textContent = 'This person is already a member of this tree';
        } else {
          emailError.textContent = data.error || 'Failed to create invite';
        }
        emailError.hidden = false;
      } else {
        inviteLinkInput.value = window.location.origin + data.url;
        inviteFormSection.hidden = true;
        inviteResultSection.hidden = false;
        showToast('Invite created');
        loadPendingInvites();
      }
    } catch {
      emailError.textContent = 'Failed to create invite';
      emailError.hidden = false;
    } finally {
      createInviteBtn.disabled = false;
    }
  });

  copyInviteBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(inviteLinkInput.value);
      showToast('Link copied to clipboard');
    } catch {
      inviteLinkInput.select();
      document.execCommand('copy');
      showToast('Link copied to clipboard');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !invitePanel.hidden) closeInvitePanel();
  });

  // Initial load if admin
  if (isAdmin) {
    loadMemberships();
  }
</script>

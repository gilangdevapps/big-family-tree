---
import Layout from '../../../layouts/Layout.astro';

const { treeId } = Astro.params;
---

<Layout title="Add your first family member">
  <div class="walkthrough-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href={`/tree/${treeId}`} class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
            <path d="M12 4l-6 6 6 6"/>
          </svg>
          Back to tree
        </a>
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="walkthrough-main">
      <div class="walkthrough-card">
        <!-- Progress -->
        <div class="progress-bar" role="progressbar" aria-valuenow="1" aria-valuemin="1" aria-valuemax="4">
          <div class="progress-fill" style="width: 25%"></div>
        </div>

        <!-- Steps -->
        <div id="steps-container">
          <!-- Step 1: Name -->
          <div class="step" data-step="1">
            <div class="step-header">
              <span class="step-label">Step 1 of 4</span>
              <h2 class="step-title">Start with the oldest person you know</h2>
              <p class="step-body">This will be the root of your family tree — the person everything connects back to.</p>
            </div>
            <div class="step-fields">
              <div class="field">
                <label for="first-name" class="field-label">First name</label>
                <input type="text" id="first-name" class="field-input" placeholder="e.g. Margaret" autocomplete="given-name" required />
                <span id="first-name-error" class="field-error" hidden></span>
              </div>
              <div class="field">
                <label for="last-name" class="field-label">Last name</label>
                <input type="text" id="last-name" class="field-input" placeholder="e.g. Smith" autocomplete="family-name" required />
                <span id="last-name-error" class="field-error" hidden></span>
              </div>
            </div>
          </div>

          <!-- Step 2: Birth & Gender -->
          <div class="step" data-step="2" hidden>
            <div class="step-header">
              <span class="step-label">Step 2 of 4</span>
              <h2 class="step-title">When were they born?</h2>
              <p class="step-body">If you're not sure about the exact date, just enter what you know.</p>
            </div>
            <div class="step-fields">
              <div class="field">
                <label for="birth-date" class="field-label">Birth date <span class="field-optional">(optional)</span></label>
                <input type="date" id="birth-date" class="field-input field-input-date" />
              </div>
              <div class="field">
                <label for="gender" class="field-label">Gender</label>
                <select id="gender" class="field-input field-select">
                  <option value="">Select…</option>
                  <option value="male">Male</option>
                  <option value="female">Female</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Step 3: Optional details -->
          <div class="step" data-step="3" hidden>
            <div class="step-header">
              <span class="step-label">Step 3 of 4</span>
              <h2 class="step-title">Anything else you know?</h2>
              <p class="step-body">Optional — add what you have. You can always come back and add more later.</p>
            </div>
            <div class="step-fields">
              <div class="field">
                <label for="birth-place" class="field-label">Birth place <span class="field-optional">(optional)</span></label>
                <input type="text" id="birth-place" class="field-input" placeholder="e.g. Dublin, Ireland" />
              </div>
              <div class="field">
                <label for="bio" class="field-label">A sentence or two <span class="field-optional">(optional)</span></label>
                <textarea id="bio" class="field-input field-textarea" rows="3" placeholder="What do you remember about this person?"></textarea>
              </div>
            </div>
          </div>

          <!-- Step 4: Confirmation -->
          <div class="step" data-step="4" hidden>
            <div class="step-header">
              <span class="step-label">Step 4 of 4</span>
              <h2 class="step-title">Add <span id="confirm-name">this person</span> as the root of your tree?</h2>
              <p class="step-body">Double-check the details below before saving.</p>
            </div>
            <div class="confirm-details" id="confirm-details">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <div id="step-error" class="step-error" hidden></div>

        <div class="step-actions">
          <button type="button" class="btn btn-ghost" id="back-btn" hidden>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M10 4L6 8l4 4"/>
            </svg>
            Back
          </button>
          <div class="step-actions-right">
            <a href={`/tree/${treeId}`} class="btn btn-ghost" id="skip-btn">Skip for now</a>
            <button type="button" class="btn btn-primary" id="next-btn">
              <span class="btn-label">Next</span>
              <span class="btn-spinner" hidden aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="spin">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28 8"/>
                </svg>
              </span>
            </button>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .walkthrough-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: radial-gradient(ellipse at 30% 20%, oklch(35% 0.03 145 / 8%) 0%, transparent 60%),
                var(--color-surface);
  }

  .top-nav {
    background-color: transparent;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-4);
  }

  .back-link, .wordmark {
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-on-surface-variant);
    transition: color var(--duration-fast) var(--ease-out-quint);
  }

  .back-link:hover { color: var(--color-on-surface); }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  /* --- Main --- */
  .walkthrough-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8) var(--space-4);
  }

  /* --- Card --- */
  .walkthrough-card {
    width: 100%;
    max-width: 520px;
    background-color: var(--color-surface-container-lowest);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-outline-variant);
    box-shadow: var(--shadow-1);
    overflow: hidden;
  }

  /* --- Progress Bar --- */
  .progress-bar {
    height: 4px;
    background-color: var(--color-outline-variant);
  }

  .progress-fill {
    height: 100%;
    background-color: var(--color-primary);
    transition: width var(--duration-slow) var(--ease-out-quint);
  }

  /* --- Steps --- */
  .step {
    padding: var(--space-8) var(--space-8) var(--space-6);
  }

  .step-header {
    margin-bottom: var(--space-8);
  }

  .step-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .step-body {
    font-size: var(--text-base);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  /* --- Fields --- */
  .step-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-on-surface);
  }

  .field-optional {
    font-weight: 400;
    color: var(--color-on-surface-variant);
  }

  .field-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-on-surface);
    background-color: var(--color-surface);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint),
                box-shadow var(--duration-fast) var(--ease-out-quint);
  }

  .field-input::placeholder { color: var(--color-on-surface-variant); opacity: 0.7; }
  .field-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px oklch(35% 0.03 145 / 15%);
  }

  .field-input-date { type: date; }
  .field-select { cursor: pointer; }
  .field-textarea { resize: vertical; min-height: 80px; }

  .field-error {
    font-size: var(--text-sm);
    color: var(--color-error);
  }

  /* --- Confirmation --- */
  .confirm-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .confirm-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .confirm-row:last-child { border-bottom: none; padding-bottom: 0; }

  .confirm-key {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-on-surface-variant);
  }

  .confirm-value {
    font-size: var(--text-base);
    font-family: var(--font-display);
    font-weight: 500;
  }

  /* --- Error --- */
  .step-error {
    margin: 0 var(--space-8);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
  }

  /* --- Actions --- */
  .step-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-8) var(--space-8);
    border-top: 1px solid var(--color-outline-variant);
  }

  .step-actions-right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* --- Buttons --- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out-quint);
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn-primary:hover { background-color: var(--color-primary-container); }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-on-surface-variant);
  }

  .btn-ghost:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .spin { animation: spin 0.8s linear infinite; }

  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .spin { animation-duration: 1.5s; } }
</style>

<script define:vars={{ treeId }}>
  import { getCurrentUser } from '../../../lib/store';

  // Auth check
  if (!getCurrentUser()) {
    window.location.href = '/auth/magic-link';
  }

  let currentStep = 1;
  const totalSteps = 4;

  const stepsContainer = document.getElementById('steps-container')!;
  const progressFill = document.querySelector('.progress-fill') as HTMLElement;
  const progressBar = document.querySelector('.progress-bar') as HTMLElement;
  const backBtn = document.getElementById('back-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const skipBtn = document.getElementById('skip-btn') as HTMLAnchorElement;
  const stepError = document.getElementById('step-error') as HTMLDivElement;
  const btnLabel = nextBtn.querySelector('.btn-label') as HTMLSpanElement;
  const btnSpinner = nextBtn.querySelector('.btn-spinner') as HTMLSpanElement;
  const confirmDetails = document.getElementById('confirm-details')!;
  const confirmName = document.getElementById('confirm-name')!;

  // Form data store
  const formData: Record<string, string> = {};

  function showStep(n: number) {
    stepsContainer.querySelectorAll('.step').forEach((el, i) => {
      (el as HTMLElement).hidden = i + 1 !== n;
    });

    const progress = (n / totalSteps) * 100;
    progressFill.style.width = `${progress}%`;
    progressBar.setAttribute('aria-valuenow', String(n));

    backBtn.hidden = n === 1;
    skipBtn.hidden = n > 1;

    if (n === totalSteps) {
      btnLabel.textContent = 'Add this person';
    } else {
      btnLabel.textContent = 'Next';
    }

    currentStep = n;
    stepError.hidden = true;
  }

  function collectStepFields(step: number): Record<string, string> {
    if (step === 1) {
      return {
        first_name: (document.getElementById('first-name') as HTMLInputElement).value.trim(),
        last_name: (document.getElementById('last-name') as HTMLInputElement).value.trim(),
      };
    }
    if (step === 2) {
      return {
        birth_date: (document.getElementById('birth-date') as HTMLInputElement).value,
        gender: (document.getElementById('gender') as HTMLSelectElement).value,
      };
    }
    if (step === 3) {
      return {
        birth_place: (document.getElementById('birth-place') as HTMLInputElement).value.trim(),
        bio: (document.getElementById('bio') as HTMLTextAreaElement).value.trim(),
      };
    }
    return {};
  }

  function validateStep(step: number): string | null {
    if (step === 1) {
      const { first_name, last_name } = collectStepFields(1);
      if (!first_name) {
        const err = document.getElementById('first-name-error')!;
        err.textContent = 'First name is required';
        err.hidden = false;
        return 'First name is required';
      }
      document.getElementById('first-name-error')!.hidden = true;
      if (!last_name) {
        const err = document.getElementById('last-name-error')!;
        err.textContent = 'Last name is required';
        err.hidden = false;
        return 'Last name is required';
      }
      document.getElementById('last-name-error')!.hidden = true;
      Object.assign(formData, { first_name, last_name });
    }
    if (step === 2) {
      Object.assign(formData, collectStepFields(2));
    }
    if (step === 3) {
      Object.assign(formData, collectStepFields(3));
    }
    return null;
  }

  function renderConfirmation() {
    confirmName.textContent = `${formData.first_name} ${formData.last_name}`;

    const rows = [
      { key: 'Full Name', value: `${formData.first_name} ${formData.last_name}` },
      { key: 'Birth Date', value: formData.birth_date || 'Unknown' },
      { key: 'Gender', value: formData.gender ? formData.gender.charAt(0).toUpperCase() + formData.gender.slice(1) : 'Not specified' },
      { key: 'Birth Place', value: formData.birth_place || 'Not specified' },
      { key: 'About', value: formData.bio || 'Nothing added yet' },
    ];

    confirmDetails.innerHTML = rows.map(row => `
      <div class="confirm-row">
        <span class="confirm-key">${row.key}</span>
        <span class="confirm-value">${escapeHtml(row.value)}</span>
      </div>
    `).join('');
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  backBtn.addEventListener('click', () => {
    if (currentStep > 1) showStep(currentStep - 1);
  });

  nextBtn.addEventListener('click', async () => {
    if (currentStep < totalSteps) {
      const err = validateStep(currentStep);
      if (err) return;
      if (currentStep === totalSteps - 1) {
        renderConfirmation();
      }
      showStep(currentStep + 1);
    } else {
      // Submit
      nextBtn.disabled = true;
      btnLabel.textContent = 'Saving…';
      btnSpinner.hidden = false;
      stepError.hidden = true;

      try {
        const payload = {
          ...formData,
          is_root: true,
        };

        const res = await fetch(`/api/trees/${treeId}/members`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to save');
        }

        const member = await res.json();

        // Set as root person on tree
        await fetch(`/api/trees/${treeId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ root_person_id: member.id }),
        });

        window.location.href = `/tree/${treeId}`;
      } catch (err) {
        stepError.textContent = err instanceof Error ? err.message : 'Something went wrong';
        stepError.hidden = false;
        nextBtn.disabled = false;
        btnLabel.textContent = 'Add this person';
        btnSpinner.hidden = true;
      }
    }
  });

  showStep(1);
</script>

---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Transfer ownership">
  <div class="page-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href={`/tree/${treeId}/settings`} class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
            <path d="M12 4l-6 6 6 6"/>
          </svg>
          Back
        </a>
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="page-main container">
      <div class="settings-container">
        <div class="settings-header">
          <h1 class="settings-title">Transfer ownership</h1>
          <p class="settings-desc">
            Transferring ownership will make another member the tree owner. You will become an admin of the tree.
          </p>
          <p class="settings-note">
            Only current tree members are shown. To transfer ownership to someone not yet in the tree, invite them first from the Members page.
          </p>
        </div>

        <div id="members-loading">Loading members…</div>
        <div id="members-empty" class="empty-state" hidden>
          <p>No other members found in the system.</p>
        </div>
        <form id="transfer-form" novalidate hidden>
          <div class="field">
            <label for="new-owner" class="field-label">Transfer to</label>
            <select id="new-owner" name="new_owner_id" class="field-input field-select" required>
              <option value="">Select a user…</option>
            </select>
            <span class="field-error" id="owner-error" hidden></span>
          </div>
          <div id="form-error" class="form-error" hidden></div>
          <div class="form-actions">
            <a href="/dashboard" id="cancel-link" class="btn btn-ghost">Cancel</a>
              <button type="submit" class="btn btn-primary" id="submit-btn">
                <span class="btn-label">Transfer ownership</span>
                <span class="btn-spinner" hidden aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="spin">
                    <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28 8"/>
                  </svg>
                </span>
              </button>
            </div>
          </form>
      </div>
    </main>
  </div>
</Layout>

<style>
  .page-shell { min-height: 100dvh; display: flex; flex-direction: column; }
  .top-nav {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky; top: 0; z-index: 100;
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px; gap: var(--space-4);
  }
  .back-link {
    display: flex; align-items: center; gap: var(--space-2);
    font-size: var(--text-sm); font-weight: 500;
    color: var(--color-on-surface-variant); text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quint);
  }
  .back-link:hover { color: var(--color-on-surface); }
  .wordmark {
    display: flex; align-items: center; gap: var(--space-2);
    text-decoration: none; color: var(--color-on-surface);
    font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500;
  }
  .page-main {
    flex: 1; display: flex; align-items: flex-start; justify-content: center;
    padding-block: var(--space-12) var(--space-16);
  }
  .settings-container { width: 100%; max-width: 520px; }
  .settings-header { margin-bottom: var(--space-10); }
  .settings-title { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 500; margin-bottom: var(--space-2); }
  .settings-desc { font-size: var(--text-base); color: var(--color-on-surface-variant); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .settings-note { font-size: var(--text-sm); color: var(--color-on-surface-variant); line-height: var(--leading-relaxed); margin-bottom: var(--space-4); padding: var(--space-3) var(--space-4); background-color: var(--color-surface-container-low); border-radius: var(--radius-lg); }
  .empty-state { font-size: var(--text-base); color: var(--color-on-surface-variant); padding: var(--space-8) 0; }
  .field { display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6); }
  .field-label { font-size: var(--text-sm); font-weight: 600; }
  .field-input {
    width: 100%; padding: var(--space-3) var(--space-4);
    font-family: var(--font-body); font-size: var(--text-base);
    color: var(--color-on-surface); background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant); border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint);
  }
  .field-input:focus { border-color: var(--color-primary); }
  .field-select { cursor: pointer; }
  .field-error { font-size: var(--text-sm); color: var(--color-error); }
  .form-error {
    padding: var(--space-4); margin-bottom: var(--space-4);
    background-color: var(--color-error-container); color: var(--color-on-error-container);
    border-radius: var(--radius-lg); font-size: var(--text-sm); font-weight: 500;
  }
  .form-actions { display: flex; align-items: center; justify-content: flex-end; gap: var(--space-3); }
  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
    border-radius: var(--radius-full); border: none; cursor: pointer; text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out-quint);
  }
  .btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
  .btn-primary { background-color: var(--color-primary); color: var(--color-on-primary); }
  .btn-primary:hover:not(:disabled) { background-color: var(--color-primary-container); }
  .btn-ghost { background-color: transparent; color: var(--color-on-surface-variant); }
  .btn-ghost:hover { background-color: var(--color-surface-container); color: var(--color-on-surface); }
  .btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .spin { animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .spin { animation-duration: 1.5s; } }
</style>

<script define:vars={{ treeId }}>
  import { getCurrentUser } from '../../../lib/store';

  // Auth check
  if (!getCurrentUser()) {
    window.location.href = '/auth/magic-link';
  }

  // Update cancel link with treeId
  const cancelLink = document.getElementById('cancel-link') as HTMLAnchorElement;
  if (cancelLink) cancelLink.href = `/tree/${treeId}/settings`;

  // Load memberships client-side
  async function loadMembers() {
    const loadingEl = document.getElementById('members-loading');
    const emptyEl = document.getElementById('members-empty');
    const formEl = document.getElementById('transfer-form') as HTMLFormElement;
    const selectEl = document.getElementById('new-owner') as HTMLSelectElement;

    try {
      const res = await fetch(`/api/trees/${treeId}/memberships`);
      if (!res.ok) throw new Error();
      const memberships = await res.json();
      const currentUser = getCurrentUser();

      if (memberships.length <= 1) {
        if (loadingEl) loadingEl.hidden = true;
        if (emptyEl) emptyEl.hidden = false;
        return;
      }

      if (loadingEl) loadingEl.hidden = true;
      if (formEl) formEl.hidden = false;

      memberships.forEach((m: any) => {
        if (m.user_id !== currentUser?.id) {
          const opt = document.createElement('option');
          opt.value = m.user_id;
          opt.textContent = m.user_email || m.user_id;
          selectEl.appendChild(opt);
        }
      });
    } catch {
      if (loadingEl) loadingEl.hidden = true;
      if (emptyEl) emptyEl.hidden = false;
    }
  }
  loadMembers();

  const form = document.getElementById('transfer-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = submitBtn.querySelector('.btn-label') as HTMLSpanElement;
  const btnSpinner = submitBtn.querySelector('.btn-spinner') as HTMLSpanElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const ownerSelect = document.getElementById('new-owner') as HTMLSelectElement;
  const ownerError = document.getElementById('owner-error') as HTMLSpanElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const newOwnerId = ownerSelect.value.trim();
    if (!newOwnerId) {
      ownerError.textContent = 'Please select a user';
      ownerError.hidden = false;
      return;
    }

    submitBtn.disabled = true;
    btnLabel.textContent = 'Transferring…';
    btnSpinner.hidden = false;
    formError.hidden = true;

    try {
      const res = await fetch(`/api/trees/${treeId}/transfer`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ new_owner_id: newOwnerId }),
      });

      if (!res.ok) {
        const data = await res.json();
        throw new Error(data.error || 'Failed to transfer ownership');
      }

      window.location.href = `/tree/${treeId}/settings`;
    } catch (err) {
      formError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      formError.hidden = false;
      submitBtn.disabled = false;
      btnLabel.textContent = 'Transfer ownership';
      btnSpinner.hidden = true;
    }
  });
</script>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Create family tree">
  <div class="page-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href="/dashboard" class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
            <path d="M12 4l-6 6 6 6"/>
          </svg>
          Back
        </a>
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="page-main container">
      <div class="form-container">
        <div class="form-header">
          <h1 class="form-title">Create a new family tree</h1>
          <p class="form-subtitle">Give your tree a name — you can change it later.</p>
        </div>

        <form id="create-tree-form" novalidate>
          <div class="field">
            <label for="tree-name" class="field-label">Tree name</label>
            <input
              type="text"
              id="tree-name"
              name="name"
              class="field-input"
              placeholder="e.g. The Smith Family"
              autocomplete="off"
              maxlength="100"
              required
            />
            <span id="name-error" class="field-error" hidden></span>
            <span id="duplicate-warning" class="field-warning" hidden>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M8 3L14 13H2L8 3Z" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="8" y1="7" x2="8" y2="10"/>
                <circle cx="8" cy="12" r="0.5" fill="currentColor"/>
              </svg>
              You already have a tree with this name
            </span>
          </div>

          <fieldset class="mode-selection">
            <legend class="mode-legend">How would you like to start?</legend>
            <div class="mode-cards">
              <label class="mode-card selected" data-mode="guided">
                <input type="radio" name="mode" value="guided" checked />
                <div class="mode-card-inner">
                  <div class="mode-card-icon" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                      <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="1.5"/>
                      <path d="M10 14h8M14 10v8" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                  </div>
                  <div class="mode-card-text">
                    <span class="mode-card-title">Start with guided walkthrough</span>
                    <span class="mode-card-desc">We'll help you add your first family member step by step</span>
                  </div>
                  <div class="mode-card-check" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <circle cx="9" cy="9" r="8" fill="var(--color-primary)"/>
                      <path d="M5.5 9.5l2.5 2.5 4.5-5" stroke="var(--color-on-primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              </label>

              <label class="mode-card" data-mode="empty">
                <input type="radio" name="mode" value="empty" />
                <div class="mode-card-inner">
                  <div class="mode-card-icon" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                      <circle cx="14" cy="14" r="13" stroke="var(--color-secondary)" stroke-width="1.5" stroke-dasharray="4 3"/>
                      <circle cx="14" cy="14" r="4" fill="none" stroke="var(--color-secondary)" stroke-width="1.5"/>
                    </svg>
                  </div>
                  <div class="mode-card-text">
                    <span class="mode-card-title">Start with an empty tree</span>
                    <span class="mode-card-desc">Add members on your own time</span>
                  </div>
                  <div class="mode-card-check" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <circle cx="9" cy="9" r="8" fill="var(--color-primary)"/>
                      <path d="M5.5 9.5l2.5 2.5 4.5-5" stroke="var(--color-on-primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              </label>
            </div>
          </fieldset>

          <div id="form-error" class="form-error" hidden></div>

          <div class="form-actions">
            <a href="/dashboard" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary" id="submit-btn">
              <span class="btn-label">Create tree</span>
              <span class="btn-spinner" hidden aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="spin">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28 8"/>
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* --- Top Nav --- */
  .top-nav {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-4);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quint);
  }

  .back-link:hover {
    color: var(--color-on-surface);
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-on-surface);
  }

  .wordmark span {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  /* --- Page Main --- */
  .page-main {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-block: var(--space-16) var(--space-24);
  }

  /* --- Form Container --- */
  .form-container {
    width: 100%;
    max-width: 520px;
  }

  .form-header {
    margin-bottom: var(--space-10);
  }

  .form-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .form-subtitle {
    color: var(--color-on-surface-variant);
    font-size: var(--text-base);
  }

  /* --- Field --- */
  .field {
    margin-bottom: var(--space-6);
  }

  .field-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-on-surface);
  }

  .field-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-on-surface);
    background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out-quint),
                box-shadow var(--duration-fast) var(--ease-out-quint);
  }

  .field-input::placeholder {
    color: var(--color-on-surface-variant);
    opacity: 0.7;
  }

  .field-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px oklch(35% 0.03 145 / 15%);
  }

  .field-input[data-error] {
    border-color: var(--color-error);
  }

  .field-error {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-error);
  }

  .field-warning {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: oklch(45% 0.12 60);
    font-weight: 500;
  }

  /* --- Mode Selection --- */
  .mode-selection {
    border: none;
    padding: 0;
    margin-bottom: var(--space-8);
  }

  .mode-legend {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-on-surface);
  }

  .mode-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mode-card {
    cursor: pointer;
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--color-outline-variant);
    background-color: var(--color-surface-container-lowest);
    transition: border-color var(--duration-fast) var(--ease-out-quint),
                box-shadow var(--duration-fast) var(--ease-out-quint);
    overflow: hidden;
  }

  .mode-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .mode-card:hover {
    border-color: var(--color-primary);
  }

  .mode-card.selected {
    border-color: var(--color-primary);
    background-color: oklch(35% 0.03 145 / 6%);
  }

  .mode-card-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
  }

  .mode-card-icon {
    flex-shrink: 0;
  }

  .mode-card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mode-card-title {
    font-weight: 600;
    font-size: var(--text-base);
  }

  .mode-card-desc {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .mode-card-check {
    flex-shrink: 0;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out-quint);
  }

  .mode-card.selected .mode-card-check {
    opacity: 1;
  }

  /* --- Form Error --- */
  .form-error {
    padding: var(--space-4);
    margin-bottom: var(--space-4);
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  /* --- Form Actions --- */
  .form-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-3);
  }

  /* --- Buttons --- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out-quint),
                box-shadow var(--duration-fast) var(--ease-out-quint),
                transform var(--duration-fast) var(--ease-out-quint);
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn-primary:hover {
    background-color: var(--color-primary-container);
    transform: translateY(-1px);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-on-surface-variant);
  }

  .btn-ghost:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  /* --- Spinner --- */
  .spin {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .spin { animation-duration: 1.5s; }
  }
</style>

<script>
  import { getCurrentUser } from '../../lib/store';

  // Auth check
  if (!getCurrentUser()) {
    window.location.href = '/auth/magic-link';
  }

  const form = document.getElementById('create-tree-form') as HTMLFormElement;
  const nameInput = document.getElementById('tree-name') as HTMLInputElement;
  const nameError = document.getElementById('name-error') as HTMLSpanElement;
  const duplicateWarning = document.getElementById('duplicate-warning') as HTMLSpanElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = submitBtn.querySelector('.btn-label') as HTMLSpanElement;
  const btnSpinner = submitBtn.querySelector('.btn-spinner') as HTMLSpanElement;
  const modeCards = document.querySelectorAll('.mode-card') as NodeListOf<HTMLElement>;

  // Mode card selection
  modeCards.forEach(card => {
    card.addEventListener('click', () => {
      modeCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement;
      input.checked = true;
    });
  });

  // Duplicate name check
  let duplicateCheckTimeout: ReturnType<typeof setTimeout>;
  nameInput.addEventListener('input', () => {
    clearTimeout(duplicateCheckTimeout);
    duplicateWarning.hidden = true;
    nameInput.removeAttribute('data-error');

    if (nameInput.value.trim().length < 2) return;

    duplicateCheckTimeout = setTimeout(async () => {
      try {
        const res = await fetch('/api/trees', {
          method: 'GET',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
        });
        if (res.ok) {
          const trees = await res.json();
          const duplicate = trees.find((t: any) =>
            t.name.toLowerCase() === nameInput.value.trim().toLowerCase()
          );
          if (duplicate) {
            duplicateWarning.hidden = false;
            nameInput.setAttribute('data-error', 'true');
          }
        }
      } catch {
        // Silently fail — not critical
      }
    }, 400);
  });

  // Form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = nameInput.value.trim();
    if (!name) {
      nameError.textContent = 'Please enter a tree name';
      nameError.hidden = false;
      nameInput.setAttribute('data-error', 'true');
      nameInput.focus();
      return;
    }

    nameError.hidden = true;
    nameInput.removeAttribute('data-error');
    duplicateWarning.hidden = true;

    // Disable form
    submitBtn.disabled = true;
    btnLabel.textContent = 'Creating…';
    btnSpinner.hidden = false;
    formError.hidden = true;

    const modeInput = form.querySelector('input[name="mode"]:checked') as HTMLInputElement;
    const mode = modeInput?.value ?? 'guided';

    try {
      const res = await fetch('/api/trees', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ name, mode }),
      });

      const data = await res.json();

      if (!res.ok) {
        if (data.error === 'DUPLICATE_NAME') {
          duplicateWarning.hidden = false;
          nameInput.setAttribute('data-error', 'true');
          submitBtn.disabled = false;
          btnLabel.textContent = 'Create tree';
          btnSpinner.hidden = true;
          return;
        }
        throw new Error(data.error || 'Something went wrong');
      }

      const treeId = data.id;
      if (mode === 'guided') {
        window.location.href = `/tree/${treeId}/walkthrough`;
      } else {
        window.location.href = `/tree/${treeId}`;
      }
    } catch (err) {
      formError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      formError.hidden = false;
      submitBtn.disabled = false;
      btnLabel.textContent = 'Create tree';
      btnSpinner.hidden = true;
    }
  });
</script>

---
import Layout from '../../layouts/Layout.astro';

const { token } = Astro.params;
if (!token) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Invite">
  <div class="page-shell">
    <header class="top-nav">
      <div class="container nav-inner">
        <a href="/" class="wordmark">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="var(--color-primary)" stroke-width="2"/>
            <circle cx="14" cy="8" r="3" fill="var(--color-primary)"/>
            <circle cx="8" cy="20" r="3" fill="var(--color-primary)"/>
            <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
            <line x1="14" y1="11" x2="8" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="14" y1="11" x2="20" y2="17" stroke="var(--color-primary)" stroke-width="1.5"/>
            <line x1="8" y1="20" x2="20" y2="20" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <span>Big Family Tree</span>
        </a>
      </div>
    </header>

    <main class="page-main container">
      <div id="loading-state" class="result-card">
        <div class="result-icon info">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="spin">
            <circle cx="10" cy="10" r="8" stroke-dasharray="28 8"/>
          </svg>
        </div>
        <h1 class="result-title">Loading invite…</h1>
      </div>

      <div id="invalid-state" class="result-card" hidden>
        <div class="result-icon error">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="10" cy="10" r="8"/>
            <path d="M7 7l6 6M13 7L7 13"/>
          </svg>
        </div>
        <h1 class="result-title">Invalid invite link</h1>
        <p class="result-body" id="invalid-message">This invite link is invalid or has expired.</p>
        <a href="/dashboard" class="btn btn-primary">Go to dashboard</a>
      </div>

      <div id="used-state" class="result-card" hidden>
        <div class="result-icon error">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="10" cy="10" r="8"/>
            <path d="M7 7l6 6M13 7L7 13"/>
          </svg>
        </div>
        <h1 class="result-title">Invite already used</h1>
        <p class="result-body">This invite has already been used.</p>
        <a href="/dashboard" class="btn btn-primary">Go to dashboard</a>
      </div>

      <div id="member-state" class="result-card" hidden>
        <div class="result-icon success">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="10" cy="10" r="8"/>
            <path d="M7 10l2 2 4-4"/>
          </svg>
        </div>
        <h1 class="result-title">You're already a member</h1>
        <p class="result-body" id="member-tree-name">You already have access to this tree.</p>
        <a href="#" id="member-open-link" class="btn btn-primary">Open tree</a>
      </div>

      <div id="wrong-email-state" class="result-card" hidden>
        <div class="result-icon info">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M10 2a6 6 0 0 1 6 6v4H4V8a6 6 0 0 1 6-6z"/>
            <rect x="4" y="12" width="12" height="6" rx="2"/>
          </svg>
        </div>
        <h1 class="result-title" id="wrong-email-title">You've been invited</h1>
        <p class="result-body" id="wrong-email-body">This invite was sent to a different email address.</p>
        <a href="/auth/sign-out" class="btn btn-ghost" style="margin-top:8px">Sign out and use the correct email</a>
      </div>

      <div id="login-state" class="result-card" hidden>
        <div class="result-icon info">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M10 2a6 6 0 0 1 6 6v4H4V8a6 6 0 0 1 6-6z"/>
            <rect x="4" y="12" width="12" height="6" rx="2"/>
          </svg>
        </div>
        <h1 class="result-title" id="login-title">You've been invited</h1>
        <p class="result-body" id="login-body">Sign in with that address to join.</p>
        <a href="#" id="login-link" class="btn btn-primary">Sign in to accept invite</a>
      </div>

      <div id="join-state" class="result-card" hidden>
        <div class="result-icon success">
          <svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="10" cy="10" r="8"/>
            <path d="M7 10l2 2 4-4"/>
          </svg>
        </div>
        <h1 class="result-title" id="join-title">Join this tree?</h1>
        <p class="result-body" id="join-body">You'll join as a Family Member.</p>
        <div class="accept-actions">
          <button type="button" class="btn btn-primary" id="accept-btn">Join tree</button>
          <a href="/dashboard" class="btn btn-ghost">Cancel</a>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .page-shell { min-height: 100dvh; display: flex; flex-direction: column; }

  .top-nav {
    background-color: var(--color-surface-container-lowest);
    border-bottom: 1px solid var(--color-outline-variant);
    position: sticky; top: 0; z-index: 100;
  }

  .nav-inner {
    display: flex; align-items: center;
    height: 64px;
  }

  .wordmark {
    display: flex; align-items: center; gap: var(--space-2);
    text-decoration: none; color: var(--color-on-surface);
    font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500;
  }

  .page-main {
    flex: 1; display: flex; align-items: center; justify-content: center;
    padding-block: var(--space-16);
  }

  .result-card {
    width: 100%; max-width: 420px;
    background-color: var(--color-surface-container-lowest);
    border: 1.5px solid var(--color-outline-variant);
    border-radius: var(--radius-2xl);
    padding: var(--space-12) var(--space-10);
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: var(--space-5);
    box-shadow: var(--shadow-1);
  }

  .result-icon {
    width: 64px; height: 64px; border-radius: var(--radius-full);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: var(--space-2);
  }

  .result-icon.success { background-color: oklch(85% 0.15 145 / 15%); color: var(--color-primary); }
  .result-icon.error { background-color: var(--color-error-container); color: var(--color-error); }
  .result-icon.info { background-color: var(--color-surface-container); color: var(--color-on-surface-variant); }

  .result-title {
    font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 500;
  }

  .result-body {
    font-size: var(--text-base); color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  .accept-actions {
    display: flex; align-items: center; gap: var(--space-3); margin-top: var(--space-2);
  }

  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
    border-radius: var(--radius-full); border: none; cursor: pointer; text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out-quint);
  }
  .btn-primary { background-color: var(--color-primary); color: var(--color-on-primary); }
  .btn-primary:hover { background-color: var(--color-primary-container); }
  .btn-ghost { background-color: transparent; color: var(--color-on-surface-variant); }
  .btn-ghost:hover { background-color: var(--color-surface-container); color: var(--color-on-surface); }

  .spin { animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script define:vars={{ token }}>
  import { getInviteByToken, getTree, getCurrentUser, userHasAccess } from '../../lib/store';

  function hideAll() {
    ['loading-state', 'invalid-state', 'used-state', 'member-state',
     'wrong-email-state', 'login-state', 'join-state'].forEach(id => {
      document.getElementById(id).hidden = true;
    });
  }

  function show(id) {
    hideAll();
    document.getElementById(id).hidden = false;
  }

  async function init() {
    const invite = getInviteByToken(token);

    if (!invite) {
      show('invalid-state');
      return;
    }

    if (invite.used_at) {
      show('used-state');
      return;
    }

    const tree = getTree(invite.tree_id);
    const treeName = tree?.name ?? 'this family tree';
    const user = getCurrentUser();
    const isLoggedIn = !!user;
    const emailMatches = user?.email?.toLowerCase() === invite.email.toLowerCase();
    const alreadyMember = user && emailMatches && userHasAccess(invite.tree_id, user.id);

    if (alreadyMember) {
      document.getElementById('member-tree-name').textContent = `You already have access to ${treeName}.`;
      document.getElementById('member-open-link').href = `/tree/${invite.tree_id}`;
      show('member-state');
      return;
    }

    if (!isLoggedIn) {
      document.getElementById('login-title').textContent = `You've been invited to ${treeName}`;
      document.getElementById('login-body').textContent = `This invite was sent to ${invite.email}. Sign in with that address to join.`;
      document.getElementById('login-link').href = `/auth/magic-link?redirect=/invite/${token}`;
      show('login-state');
      return;
    }

    if (!emailMatches) {
      document.getElementById('wrong-email-title').textContent = `You've been invited to ${treeName}`;
      document.getElementById('wrong-email-body').textContent =
        `This invite was sent to ${invite.email}. The email address you're signed in with doesn't match this invite.`;
      show('wrong-email-state');
      return;
    }

    // Logged in and email matches
    document.getElementById('join-title').textContent = `Join ${treeName}?`;
    document.getElementById('join-body').textContent =
      `You'll join as ${invite.role === 'admin' ? 'Admin' : 'Family Member'} and can view and edit family profiles.`;
    show('join-state');

    // Accept button handler
    document.getElementById('accept-btn').addEventListener('click', async () => {
      const btn = document.getElementById('accept-btn');
      btn.disabled = true;
      btn.textContent = 'Joining…';
      try {
        const res = await fetch(`/api/invites/${token}/accept`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) {
          alert(data.error || 'Failed to join tree');
          btn.disabled = false;
          btn.textContent = 'Join tree';
        } else {
          window.location.href = `/tree/${invite.tree_id}`;
        }
      } catch {
        alert('Failed to join tree');
        btn.disabled = false;
        btn.textContent = 'Join tree';
      }
    });
  }

  init();
</script>
